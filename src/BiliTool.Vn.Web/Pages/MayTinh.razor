    // ── Tạo hồ sơ trẻ từ Máy Tính ────────────────────────────

    private bool hienModalTaoBe = false;
    private TaoBenhNhanDto formTao = new();
    private DateTime ngayGioSinhModal = DateTime.Now;
    private string thongBaoLoiModal = string.Empty;
    private bool dangLuuHoSo = false;

    private void MoModalTaoHoSo()
    {
        if (!NguoiDung.DaDangNhap)
        {
            Toast.ShowWarning(T["LoginRequired_Toast"] ?? "Vui lòng đăng nhập để lưu trữ dữ liệu bệnh nhi!");
            return;
        }

        formTao = new TaoBenhNhanDto
        {
            TuoiThaiTuan = model.TuoiThaiTuan,
            BenhTanHuyetMienDichHoacThieuG6PD = model.YeuToNguyCo.BenhTanHuyetMienDichHoacThieuG6PD,
            NhiemKhuanHuyetHoacNghiNgo = model.YeuToNguyCo.NhiemKhuanHuyetHoacNghiNgo,
            AlbuminThapDuoi3gDl = model.YeuToNguyCo.AlbuminThapDuoi3gDl,
            TinhTrangLamSangKhongOnDinh = model.YeuToNguyCo.TinhTrangLamSangKhongOnDinh,
            ETCOcPpm = model.YeuToNguyCo.ETCOcPpm,
            AnhChiBiVangDaCanChieuDen = model.YeuToNguyCo.AnhChiBiVangDaCanChieuDen,
            MeBuMeHoanToan = model.YeuToNguyCo.MeBuMeHoanToan,
            VangDaTrong24hDau = model.YeuToNguyCo.VangDaTrong24hDau,
            BenhTanHuyetRh = model.YeuToNguyCo.BenhTanHuyetRh,
            BenhTanHuyetABO = model.YeuToNguyCo.BenhTanHuyetABO
        };

        if (dungNgayGio && model.NgaySinh.HasValue)
        {
            ngayGioSinhModal = model.NgaySinh.Value.Date.Add(LayGioSinh());
        }
        else if (model.TuoiTheoGio.HasValue)
        {
            ngayGioSinhModal = DateTime.Now.AddHours(-model.TuoiTheoGio.Value);
        }

        thongBaoLoiModal = string.Empty;
        hienModalTaoBe = true;
    }

    private void DongModalTaoBe() => hienModalTaoBe = false;

    private async Task TaoHoSoTre()
    {
        thongBaoLoiModal = string.Empty;
        if (string.IsNullOrWhiteSpace(formTao.HoTenBenhNhan))
        {
            thongBaoLoiModal = T["EnterName_Error"] ?? "Vui lòng nhập họ tên bé.";
            return;
        }

        dangLuuHoSo = true;
        try
        {
            var userId = NguoiDung.Id ?? NguoiDung.Email ?? "";
            formTao.NgayGioSinhStr = ngayGioSinhModal.ToString("dd/MM/yyyy HH:mm");
            
            var bn = await Mediator.Send(new TaoBenhNhanCommand(userId, formTao));

            var thoiGianLayMauThucTe = DateTime.Now;
            if (dungNgayGio && model.NgayLayMau.HasValue)
            {
                thoiGianLayMauThucTe = model.NgayLayMau.Value.Date.Add(LayGioLayMau());
            }
            
            var xnDto = new ThemXetNghiemDto
            {
                BenhNhanId = bn.Id,
                BilirubinMgDl = donViDoStr == "UmolL" ? Math.Round(model.TongBilirubin / 17.104m, 2) : model.TongBilirubin,
                ThoiGianLayMauTuyChon = thoiGianLayMauThucTe
            };
            await Mediator.Send(new ThemXetNghiemCommand(userId, xnDto));

            hienModalTaoBe = false;
            Toast.ShowSuccess(T["Save_Success"] ?? "Lưu thành công! Bạn có thể xem hồ sơ ở phần báo cáo.");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            thongBaoLoiModal = ex.Message;
        }
        finally
        {
            dangLuuHoSo = false;
        }
    }
