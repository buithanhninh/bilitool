    }

    private async Task MoLaiMayTinh()
    {
        cheDoTapTrungKetQua = false;
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("bilitool.focusCalculatorForm");
    }

    private string FormatBilirubinTomTat() => donViDoStr == "UmolL"
        ? $"{ketQua?.BilirubinUmolL:F0} μmol/L"
        : $"{ketQua?.BilirubinMgDl:F1} mg/dL";

    private async Task TinhToan()
    {
        dangTinhToan = true;
        try
        {
            model.YeuToNguyCo.ETCOcPpm = etcoc;
            model.DonViDo = donViDoStr == "UmolL" ? DonViDo.UmolL : DonViDo.MgDl;

            if (dungNgayGio)
            {
                model.GioSinh    = LayGioSinh();
                model.GioLayMau  = LayGioLayMau();
            }

            var cmd = new TinhToanBilirubinCommand(model);
            ketQua = await Mediator.Send(cmd);
            cheDoTapTrungKetQua = true;
            Toast.ShowSuccess(T["Calc_Success"] ?? "Tính toán thành công!");
            await InvokeAsync(StateHasChanged);
            await JS.InvokeVoidAsync("bilitool.scrollToTop");

            // Lưu lịch sử
            try 
            {
                var phienId = await PhienLamViec.LayHoacTaoPhienAsync();
                await Mediator.Send(new LuuLichSuCommand(phienId, model, ketQua));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Không thể lưu lịch sử: {ex.Message}");
            }
        }
        catch (BiliTool.Vn.Application.LoiXacThucException ex)
        {
            var loi = string.Join("; ", ex.LoiXacThuc.Values.SelectMany(v => v));
            Toast.ShowError(loi);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{(T["DeleteError"] ?? "Lỗi")}: {ex.Message}");
        }
        finally
        {
            dangTinhToan = false;
        }
    }

    private async Task SaoChepBaoCao(string textBaoCao)
    {
        if (!string.IsNullOrEmpty(textBaoCao))
        {
            await JS.InvokeVoidAsync("bilitool.copyToClipboard", textBaoCao);
            Toast.ShowSuccess(T["ReportCopied"] ?? "Đã sao chép báo cáo vào clipboard!");
        }
    }

