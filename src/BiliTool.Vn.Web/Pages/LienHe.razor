<style>
    .contact-banner {
        background:
            radial-gradient(circle at 8% 0%, rgba(15, 95, 143, .16), transparent 34%),
            linear-gradient(145deg, rgba(255,255,255,.96), rgba(239,249,252,.92));
        border: 1px solid rgba(15, 95, 143, .12);
        border-radius: 28px;
        color: #07111f;
        padding: 36px;
        box-shadow: 0 24px 64px rgba(8, 45, 77, .14), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
        overflow: hidden;
    }

    .contact-banner::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image:
            linear-gradient(rgba(15, 95, 143, .035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(15, 95, 143, .035) 1px, transparent 1px);
        background-size: 36px 36px;
        mask-image: linear-gradient(135deg, rgba(0,0,0,.72), rgba(0,0,0,.08));
    }

    .contact-content {
        position: relative;
        z-index: 2;
    }

    .contact-content h2 {
        display: flex;
        align-items: center;
        gap: 14px;
        color: #0f5f8f;
        font-size: clamp(1.55rem, 2.4vw, 2rem);
        font-weight: 900;
        letter-spacing: -.04em;
        margin-bottom: 18px;
    }
    
    .contact-content h2 i {
        width: 48px;
        height: 48px;
        display: inline-grid;
        place-items: center;
        margin-right: 0;
        border-radius: 18px;
        color: #fff;
        background: linear-gradient(145deg, #0f5f8f, #0f766e);
        box-shadow: 0 16px 32px rgba(15, 95, 143, .22);
    }

    .contact-desc {
        max-width: 980px;
        font-size: 1.03rem;
        line-height: 1.75;
        color: #334155;
        margin-bottom: 28px;
        padding: 16px 18px;
        border-left: 4px solid rgba(15, 118, 110, .36);
        border-radius: 0 18px 18px 0;
        background: rgba(255,255,255,.62);
    }

    .contact-cards {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .contact-card {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, .78);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(15, 23, 42, .08);
        padding: 18px 20px;
        border-radius: 20px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, .06);
        transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    }

    .contact-card:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, .94);
        border-color: rgba(15, 95, 143, .22);
        box-shadow: 0 18px 38px rgba(8, 45, 77, .12);
    }

    .contact-card-link { position: relative; color: inherit; text-decoration: none; cursor: pointer; }
    .contact-card-link:focus-visible { outline: 3px solid rgba(0, 104, 255, .28); outline-offset: 3px; }
    .contact-card-zalo { border-color: rgba(0, 104, 255, .18); background: linear-gradient(100deg, rgba(238, 247, 255, .96), rgba(255, 255, 255, .86)); }
    .contact-card-zalo:hover { border-color: rgba(0, 104, 255, .38); box-shadow: 0 18px 38px rgba(0, 104, 255, .12); }
    .contact-card-zalo .contact-icon-zalo { color: #fff; background: #0068ff; border-color: #0068ff; font-family: Arial, sans-serif; font-size: .92rem; font-weight: 800; letter-spacing: -.04em; box-shadow: 0 10px 24px rgba(0, 104, 255, .22); }
    .contact-action { margin-top: 3px; color: #0068ff; font-size: .78rem; font-weight: 700; }
    .contact-action i { margin-left: 4px; font-size: .7rem; }
    .contact-chevron { margin-left: auto; padding-left: 18px; color: #0068ff; font-size: .9rem; transition: transform .2s ease; }
    .contact-card-link:hover .contact-chevron { transform: translateX(4px); }

    .contact-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(145deg, rgba(15,95,143,.10), rgba(15,118,110,.10));
        color: #0f5f8f;
        border: 1px solid rgba(15,95,143,.14);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
        margin-right: 20px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.9), 0 10px 22px rgba(15,95,143,.08);
    }

    .contact-info {
        display: flex;
        flex-direction: column;
    }

    .contact-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 1px;
        color: #64748b;
        margin-bottom: 5px;
    }

    .contact-value {
        color: #07111f;
        font-size: 1.45rem;
        font-weight: 900;
        letter-spacing: -.025em;
    }

    .contact-link {
        color: #0f5f8f;
        text-decoration: none;
        font-size: 1.4rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .contact-link:hover {
        color: #0f766e;
        text-decoration: underline;
    }
    
    .contact-link i {
        font-size: 1rem;
    }

    @@media (max-width: 768px) {
        .contact-banner {
            padding: 25px;
        }
        .contact-content h2 {
            font-size: 1.6rem;
        }
        .contact-desc {
            font-size: 1.05rem;
        }
        .contact-value {
            font-size: 1.2rem;
        }
        .contact-icon {
            width: 50px;
            height: 50px;
            font-size: 1.2rem;
            margin-right: 15px;
        }
        .contact-action { font-size: .72rem; }
        .contact-chevron { padding-left: 8px; }
    }
</style>
