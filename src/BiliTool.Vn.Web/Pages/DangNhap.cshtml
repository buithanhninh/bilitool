@page "/dang-nhap"
@model BiliTool.Vn.Web.Pages.DangNhapModel
@{
    var lang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLower();
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (lang == "en")
    {
        <title>Sign In — BiliTool.Vn</title>
    }
    else if (lang == "fr")
    {
        <title>Connexion — BiliTool.Vn</title>
    }
    else
    {
        <title>Đăng nhập — BiliTool.Vn</title>
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Be Vietnam Pro', sans-serif; background: #f0f4f8; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .login-card { background: white; border-radius: 20px; padding: 48px 40px; max-width: 460px; width: 100%; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.12); }
        .logo { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 28px; }
        .logo i { font-size: 2rem; color: #1a6b9a; }
        .logo span { font-size: 1.6rem; font-weight: 700; color: #1a263a; }
        h1 { font-size: 1.3rem; color: #1a263a; margin-bottom: 8px; }
        .subtitle { font-size: 0.9rem; color: #6b7280; margin-bottom: 32px; line-height: 1.6; }
        
        .form-group { text-align: left; margin-bottom: 20px; }
        .form-label { display: block; font-size: 0.9rem; color: #374151; font-weight: 600; margin-bottom: 8px; }
        .form-control { width: 100%; padding: 12px 16px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; color: #1f2937; transition: border-color 0.2s; font-family: inherit; }
        .form-control:focus { outline: none; border-color: #1a6b9a; box-shadow: 0 0 0 3px rgba(26, 107, 154, 0.1); }
        
        .btn-primary { width: 100%; padding: 12px; background: #1a6b9a; color: white; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.2s; margin-top: 10px; }
        .btn-primary:hover { background: #15557a; }
        
        .error-message { background: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 8px; font-size: 0.9rem; margin-bottom: 20px; border: 1px solid #fca5a5; }

        /* Google Button */
        .btn-google {
            display: flex; align-items: center; gap: 12px; justify-content: center;
            width: 100%; padding: 12px 20px;
            background: white; border: 1px solid #d1d5db;
            border-radius: 8px; color: #374151; font-size: 0.95rem; font-weight: 600;
            cursor: pointer; text-decoration: none;
            transition: all 0.2s; margin-top: 16px;
        }
        .btn-google:hover { background: #f9fafb; border-color: #9ca3af; }
        .btn-google svg { width: 20px; height: 20px; flex-shrink: 0; }
        
        .divider { display: flex; align-items: center; gap: 16px; margin: 24px 0; color: #9ca3af; font-size: 0.85rem; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #e5e7eb; }
        
        .links-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; margin-top: -10px; margin-bottom: 20px; }
        .links-row a { color: #1a6b9a; text-decoration: none; font-weight: 500; }
        .links-row a:hover { text-decoration: underline; }

        .register-text { margin-top: 24px; font-size: 0.9rem; color: #6b7280; }
        .register-text a { color: #1a6b9a; text-decoration: none; font-weight: 600; }
        .register-text a:hover { text-decoration: underline; }

        /* Config warning */
        .config-warning { background: #fef3c7; border: 1.5px solid #f59e0b; border-radius: 12px; padding: 20px; margin: 24px 0; text-align: left; }
        .config-warning h3 { color: #92400e; font-size: 0.95rem; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
        .config-warning p { color: #78350f; font-size: 0.83rem; line-height: 1.6; }
        
        .btn-anon { display: inline-flex; align-items: center; gap: 8px; color: #6b7280; font-size: 0.9rem; text-decoration: none; padding: 10px 20px; border-radius: 8px; border: 1.5px solid #e5e7eb; width: 100%; justify-content: center; transition: all 0.2s; margin-top: 20px;}
        .btn-anon:hover { background: #f9fafb; color: #374151; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo">
            <i class="fas fa-baby"></i>
            <span>BiliTool.Vn</span>
        </div>

        @if (lang == "en")
        {
            <h1>Welcome back!</h1>
            <p class="subtitle">Sign in to save calculation history and sync data.</p>
        }
        else if (lang == "fr")
        {
            <h1>Bon retour !</h1>
            <p class="subtitle">Connectez-vous pour enregistrer l'historique et synchroniser les données.</p>
        }
        else
        {
            <h1>Chào mừng trở lại!</h1>
            <p class="subtitle">Đăng nhập để lưu lịch sử tính toán và đồng bộ dữ liệu.</p>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-message">
                <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post" asp-page-handler="Local">
            <div class="form-group">
                @if (lang == "en")
                {
                    <label class="form-label" for="Email">Email Address</label>
                }
                else if (lang == "fr")
                {
                    <label class="form-label" for="Email">Adresse E-mail</label>
                }
                else
                {
                    <label class="form-label" for="Email">Địa chỉ Email</label>
                }
                <input type="email" id="Email" name="Email" class="form-control" value="@Model.Email" required placeholder="nhapemail@domain.com" />
            </div>

            <div class="form-group">
                @if (lang == "en")
                {
                    <label class="form-label" for="Password">Password</label>
                }
                else if (lang == "fr")
                {
                    <label class="form-label" for="Password">Mot de passe</label>
                }
                else
                {
                    <label class="form-label" for="Password">Mật khẩu</label>
                }
                <input type="password" id="Password" name="Password" class="form-control" required placeholder="••••••••" />
            </div>

            <div class="links-row">
                <div></div>
                @if (lang == "en")
                {
                    <a href="/quen-mat-khau">Forgot password?</a>
                }
                else if (lang == "fr")
                {
                    <a href="/quen-mat-khau">Mot de passe oublié ?</a>
                }
                else
                {
                    <a href="/quen-mat-khau">Quên mật khẩu?</a>
                }
            </div>

            @if (lang == "en")
            {
                <button type="submit" class="btn-primary">Sign In</button>
            }
            else if (lang == "fr")
            {
                <button type="submit" class="btn-primary">Se connecter</button>
            }
            else
            {
                <button type="submit" class="btn-primary">Đăng nhập</button>
            }
        </form>

        @if (lang == "en")
        {
            <div class="divider">or</div>
        }
        else if (lang == "fr")
        {
            <div class="divider">ou</div>
        }
        else
        {
            <div class="divider">hoặc</div>
        }

        <form method="post" asp-page-handler="Google">
            @if (Model.GoogleChuaCauHinh)
            {
                <div class="config-warning">
                    @if (lang == "en")
                    {
                        <h3><i class="fas fa-exclamation-triangle"></i> Google OAuth not configured</h3>
                        <p>This feature is disabled because the system ClientId has not been set.</p>
                    }
                    else if (lang == "fr")
                    {
                        <h3><i class="fas fa-exclamation-triangle"></i> Google OAuth non configuré</h3>
                        <p>Cette fonctionnalité est désactivée car le ClientId du système n'est pas configuré.</p>
                    }
                    else
                    {
                        <h3><i class="fas fa-exclamation-triangle"></i> Chưa cấu hình Google OAuth</h3>
                        <p>Tính năng này đang bị vô hiệu hóa vì hệ thống chưa thiết lập ClientId.</p>
                    }
                </div>
            }
            else
            {
                <button type="submit" class="btn-google">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    @if (lang == "en")
                    {
                        <span>Continue with Google</span>
                    }
                    else if (lang == "fr")
                    {
                        <span>Continuer avec Google</span>
                    }
                    else
                    {
                        <span>Tiếp tục với Google</span>
                    }
                </button>
            }
        </form>

        <p class="register-text">
            @if (lang == "en")
            {
                <span>Don't have an account? <a href="/dang-ky">Sign up now</a></span>
            }
            else if (lang == "fr")
            {
                <span>Pas de compte ? <a href="/dang-ky">Inscrivez-vous maintenant</a></span>
            }
            else
            {
                <span>Chưa có tài khoản? <a href="/dang-ky">Đăng ký ngay</a></span>
            }
        </p>

        <a href="/" class="btn-anon" style="border:none; margin-top: 10px; background: none;">
            @if (lang == "en")
            {
                <span><i class="fas fa-arrow-left"></i> Back to homepage</span>
            }
            else if (lang == "fr")
            {
                <span><i class="fas fa-arrow-left"></i> Retour à l'accueil</span>
            }
            else
            {
                <span><i class="fas fa-arrow-left"></i> Về trang chủ</span>
            }
        </a>
    </div>
</body>
</html>
