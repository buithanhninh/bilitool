@page "/"
@using System.Globalization
@{
    var currentLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLower() ?? "vi";
}
<!DOCTYPE html>
<html lang="@currentLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="application-name" content="BiliTool.Vn" />
    <meta name="apple-mobile-web-app-title" content="BiliTool.Vn" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="format-detection" content="telephone=no" />
    <base href="~/" />
    <!-- HeadOutlet: cho phép các trang Blazor inject PageTitle + HeadContent động -->
    <component type="typeof(Microsoft.AspNetCore.Components.Web.HeadOutlet)"
               render-mode="ServerPrerendered" />

    <!-- Preconnect & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Bootstrap utilities used by shared and admin pages -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- App CSS -->
    <link href="css/site.css?v=1.3.28" rel="stylesheet" />
    <link href="css/bilitool.css?v=1.3.28" rel="stylesheet" />
    <link href="css/admin-premium.css?v=1.3.28" rel="stylesheet" />
    <link href="css/premium-ui.css?v=1.3.28" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=1.3.16" sizes="any" />
    <link rel="icon" type="image/png" href="/icons/favicon-32x32.png?v=1.3.16" sizes="32x32" />
    <link rel="icon" type="image/png" href="/icons/favicon-16x16.png?v=1.3.16" sizes="16x16" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png?v=1.3.16" sizes="180x180" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json?v=1.3.16" />
    <meta name="theme-color" content="#0f766e" />
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@graph": [
        {
          "@@type": "Organization",
          "@@id": "https://bilitool.vn/#organization",
          "name": "BiliTool.Vn",
          "url": "https://bilitool.vn/",
          "logo": "https://bilitool.vn/icons/icon-512.png",
          "image": "https://bilitool.vn/images/og-bilitool-1200x630.png",
          "sameAs": [
            "https://github.com/buithanhninh/bilitool",
            "https://drninhmai.com/"
          ],
          "contactPoint": {
            "@@type": "ContactPoint",
            "telephone": "+84936626007",
            "contactType": "customer support",
            "areaServed": "VN",
            "availableLanguage": ["vi", "en", "fr"]
          }
        },
        {
          "@@type": "WebSite",
          "@@id": "https://bilitool.vn/#website",
          "url": "https://bilitool.vn/",
          "name": "BiliTool.Vn",
          "alternateName": "Máy tính Bilirubin sơ sinh BiliTool.Vn",
          "publisher": { "@@id": "https://bilitool.vn/#organization" },
          "inLanguage": "vi-VN"
        },
        {
          "@@type": "SoftwareApplication",
          "@@id": "https://bilitool.vn/#software",
          "name": "BiliTool.Vn",
          "applicationCategory": "MedicalApplication",
          "operatingSystem": "Web",
          "url": "https://bilitool.vn/",
          "description": "Công cụ hỗ trợ lâm sàng tính ngưỡng bilirubin sơ sinh theo AAP 2022 và NICE CG98.",
          "isAccessibleForFree": true,
          "publisher": { "@@id": "https://bilitool.vn/#organization" },
          "offers": {
            "@@type": "Offer",
            "price": "0",
            "priceCurrency": "VND"
          }
        }
      ]
    }
    </script>
</head>
<body class="bili-splash-active">
    <div id="bili-app-splash"
         class="bili-app-splash"
         role="status"
         aria-live="polite"
         aria-label="@(currentLang == "en" ? "Loading BiliTool.Vn" : currentLang == "fr" ? "Chargement de BiliTool.Vn" : "Đang tải BiliTool.Vn")">
        <div class="bili-app-splash__aura" aria-hidden="true"></div>
        <div class="bili-app-splash__stage" aria-hidden="true">
            <div class="bili-app-splash__ring bili-app-splash__ring--outer"></div>
            <div class="bili-app-splash__ring bili-app-splash__ring--middle"></div>
            <div class="bili-app-splash__ring bili-app-splash__ring--inner"></div>
            <div class="bili-app-splash__ticks"></div>
            <div class="bili-app-splash__orbit bili-app-splash__orbit--one"><span></span></div>
            <div class="bili-app-splash__orbit bili-app-splash__orbit--two"><span></span></div>
            <div class="bili-app-splash__signal bili-app-splash__signal--baby">
                <svg viewBox="0 0 32 32" role="presentation"><circle cx="16" cy="10" r="5"></circle><path d="M8 26c.7-6 3.4-9 8-9s7.3 3 8 9M11 12.5c-2.4.5-4-1.1-4-3.2M21 12.5c2.4.5 4-1.1 4-3.2"></path></svg>
            </div>
            <div class="bili-app-splash__signal bili-app-splash__signal--drop">
                <svg viewBox="0 0 32 32" role="presentation"><path d="M16 3C13 8.2 8 13.1 8 19a8 8 0 0 0 16 0c0-5.9-5-10.8-8-16Z"></path><path d="M12 20.5c.5 2.1 1.8 3.2 4 3.5"></path></svg>
            </div>
            <div class="bili-app-splash__signal bili-app-splash__signal--light">
                <svg viewBox="0 0 32 32" role="presentation"><path d="M10 18h12l-2-7h-8l-2 7ZM16 4v3M7.5 7.5l2.2 2.2M24.5 7.5l-2.2 2.2M8 23h16M11 27h10"></path><path d="M12 18v5M20 18v5"></path></svg>
            </div>
            <div class="bili-app-splash__signal bili-app-splash__signal--chart">
                <svg viewBox="0 0 32 32" role="presentation"><path d="M6 5v21h21"></path><path d="m9 21 5-6 4 3 7-9"></path><circle cx="9" cy="21" r="1.2"></circle><circle cx="14" cy="15" r="1.2"></circle><circle cx="18" cy="18" r="1.2"></circle><circle cx="25" cy="9" r="1.2"></circle></svg>
            </div>
            <div class="bili-app-splash__logo-shell">
                <img src="/icons/bilitool-icon.svg" alt="" width="84" height="84" />
            </div>
        </div>
        <div class="bili-app-splash__brand" aria-hidden="true">
            <strong>BiliTool.Vn</strong>
            <span>AAP 2022 · NICE CG98</span>
        </div>
        <div class="bili-app-splash__progress" aria-hidden="true"><span></span></div>
    </div>
    <script>
        window.__biliSplashStartedAt = performance.now();
    </script>

    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui" class="blazor-error-ui-custom">
        @if (currentLang == "en")
        {
            <span><i class="fas fa-exclamation-circle text-warning"></i> An error has occurred.</span>
            <a href="" class="reload btn btn-sm btn-outline-warning ms-2">Reload</a>
        }
        else if (currentLang == "fr")
        {
            <span><i class="fas fa-exclamation-circle text-warning"></i> Une erreur est survenue.</span>
            <a href="" class="reload btn btn-sm btn-outline-warning ms-2">Recharger</a>
        }
        else
        {
            <span><i class="fas fa-exclamation-circle text-warning"></i> Đã xảy ra lỗi hệ thống.</span>
            <a href="" class="reload btn btn-sm btn-outline-warning ms-2">Tải lại trang</a>
        }
        <a class="dismiss ms-2" style="cursor:pointer;"><i class="fas fa-times"></i></a>
    </div>

    <!-- Custom Reconnect UI -->
    <div id="components-reconnect-modal" class="components-reconnect-hide my-reconnect-modal">
        <div class="show">
            <div class="reconnect-box shadow-lg">
                <i class="fas fa-wifi fa-beat fa-2x text-primary mb-2"></i>
                @if (currentLang == "en")
                {
                    <h5 class="mb-1 text-dark">Reconnecting...</h5>
                    <p class="text-muted small mb-0">Unstable network connection, please wait.</p>
                }
                else if (currentLang == "fr")
                {
                    <h5 class="mb-1 text-dark">Reconnexion...</h5>
                    <p class="text-muted small mb-0">Connexion réseau instable, veuillez patienter.</p>
                }
                else
                {
                    <h5 class="mb-1 text-dark">Đang kết nối lại...</h5>
                    <p class="text-muted small mb-0">Đường truyền mạng không ổn định, vui lòng chờ.</p>
                }
            </div>
        </div>
        <div class="failed">
            <div class="reconnect-box shadow-lg border-danger border border-2">
                <i class="fas fa-satellite-dish fa-2x text-danger mb-2"></i>
                @if (currentLang == "en")
                {
                    <h5 class="mb-1 text-danger">Connection lost</h5>
                    <p class="text-muted small mb-0">Automatically reloading page...</p>
                }
                else if (currentLang == "fr")
                {
                    <h5 class="mb-1 text-danger">Connexion perdue</h5>
                    <p class="text-muted small mb-0">Rechargement automatique...</p>
                }
                else
                {
                    <h5 class="mb-1 text-danger">Mất kết nối máy chủ</h5>
                    <p class="text-muted small mb-0">Đang tự động tải lại trang...</p>
                }
            </div>
        </div>
        <div class="rejected">
            <div class="reconnect-box shadow-lg border-warning border border-2">
                <i class="fas fa-stopwatch fa-2x text-warning mb-2"></i>
                @if (currentLang == "en")
                {
                    <h5 class="mb-1 text-warning">Session expired</h5>
                    <p class="text-muted small mb-0">Automatically reloading page...</p>
                }
                else if (currentLang == "fr")
                {
                    <h5 class="mb-1 text-warning">Session expirée</h5>
                    <p class="text-muted small mb-0">Rechargement automatique...</p>
                }
                else
                {
                    <h5 class="mb-1 text-warning">Phiên làm việc hết hạn</h5>
                    <p class="text-muted small mb-0">Đang tự động tải lại trang...</p>
                }
            </div>
        </div>
    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <!-- JS Interop -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="js/bilitool-interop.js?v=@DateTime.Now.Ticks"></script>
    <script src="js/admin-charts.js?v=@DateTime.Now.Ticks"></script>

    <script src="_framework/blazor.server.js" autostart="false"></script>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js').catch(() => { });
            });
        }

        const revealBiliTool = () => {
            const splash = document.getElementById('bili-app-splash');
            if (!splash || splash.classList.contains('is-leaving')) return;

            const minimumDisplay = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 1000 : 3500;
            const elapsed = performance.now() - (window.__biliSplashStartedAt || 0);
            const delay = Math.max(0, minimumDisplay - elapsed);

            window.setTimeout(() => {
                splash.classList.add('is-leaving');
                document.body.classList.remove('bili-splash-active');
                window.setTimeout(() => splash.remove(), 750);
            }, delay);
        };

        const splashFallback = window.setTimeout(revealBiliTool, 10000);

        Blazor.start({
            configureSignalR: function (builder) {
                builder.configureLogging(5);
            },
            reconnectionOptions: {
                maxRetries: 30, // Thử lại rất nhiều lần trước khi bỏ cuộc (khoảng 1 phút)
                retryIntervalMilliseconds: 2000
            }
        }).then(() => {
            window.clearTimeout(splashFallback);
            revealBiliTool();

            // Observer to watch for failed/rejected states and auto reload
            const reconnectModal = document.getElementById('components-reconnect-modal');
            if (reconnectModal) {
                const observer = new MutationObserver(function(mutations) {
                    const classList = reconnectModal.classList;
                    if (classList.contains('failed') || classList.contains('rejected')) {
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500); // Reload sau 1.5s để user kịp đọc thông báo
                    }
                });
                observer.observe(reconnectModal, { attributes: true, attributeFilter: ['class'] });
            }
        }).catch(() => {
            revealBiliTool();
        });
    </script>
</body>
</html>
