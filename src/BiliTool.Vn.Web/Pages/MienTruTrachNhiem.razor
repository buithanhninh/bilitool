<style>
    .custom-typography h2 {
        color: var(--primary);
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .custom-typography h2 i {
        opacity: 0.8;
    }

    .disclaimer-section {
        margin-bottom: 2.5rem;
    }

    .mt-extra {
        margin-top: 3.5rem;
    }

    .disclaimer-card {
        background-color: #fffcf5;
        border: 2px solid #ffeeba;
        border-radius: var(--radius-lg);
        padding: 30px;
        box-shadow: var(--shadow-sm);
    }
    
    .disclaimer-card p {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #5a4b18;
        text-align: justify;
        margin-bottom: 1.5rem;
    }

    .disclaimer-alert {
        background-color: #f8dbdf;
        border-left: 4px solid #dc3545;
        padding: 20px;
        border-radius: 4px;
        margin-top: 2rem;
    }
    
    .disclaimer-alert p {
        color: #842029;
        margin-bottom: 0;
        font-weight: 500;
    }

    .plain-text {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #495057;
        text-align: justify;
    }

    @@media (max-width: 768px) {
        .custom-typography h2 {
            font-size: 1.4rem;
        }
        .disclaimer-card, .plain-text {
            font-size: 1.05rem;
            padding: 20px;
        }
    }
</style>
