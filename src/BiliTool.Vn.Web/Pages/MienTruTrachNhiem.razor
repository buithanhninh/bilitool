@page "/mien-tru-trach-nhiem"
@using System.Globalization

@{
    var lang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLower();
}

@if (lang == "en")
{
    <PageTitle>Medical Disclaimer | BiliTool.Vn</PageTitle>

    <HeadContent>
        <meta name="description" content="Terms of Use of BiliTool.Vn. The software is for clinical decision support only and does not replace the professional judgement of pediatric or neonatal doctors." />
        <link rel="canonical" href="https://bilitool.vn/mien-tru-trach-nhiem" />
