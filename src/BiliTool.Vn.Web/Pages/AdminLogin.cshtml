@page "/admin/login"
@model BiliTool.Vn.Web.Pages.AdminLoginModel
@{
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLower();
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (lang == "en")
    {
        <title>Admin Login - BiliTool.Vn</title>
    }
    else if (lang == "fr")
    {
        <title>Connexion Administrateur - BiliTool.Vn</title>
    }
    else
    {
        <title>Đăng nhập Quản trị - BiliTool.Vn</title>
    }
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }
        .login-card {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
        }
        .login-card h3 {
            text-align: center;
            margin-bottom: 1.5rem;
            color: #2b3954;
        }
    </style>
</head>
<body>

<div class="login-card">
    @if (lang == "en")
    {
        <h3><i class="fas fa-shield-alt text-primary"></i> Admin Login</h3>
    }
    else if (lang == "fr")
    {
        <h3><i class="fas fa-shield-alt text-primary"></i> Connexion Admin</h3>
    }
    else
    {
        <h3><i class="fas fa-shield-alt text-primary"></i> Đăng nhập Quản trị</h3>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @Model.ErrorMessage
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            @if (lang == "en")
            {
                <label for="Username" class="form-label">Username</label>
            }
            else if (lang == "fr")
            {
                <label for="Username" class="form-label">Nom d'utilisateur</label>
            }
            else
            {
                <label for="Username" class="form-label">Tài khoản</label>
            }
            <input type="text" class="form-control" id="Username" name="Username" value="@Model.Username" required autofocus />
        </div>
        <div class="mb-3">
            @if (lang == "en")
            {
                <label for="Password" class="form-label">Password</label>
            }
            else if (lang == "fr")
            {
                <label for="Password" class="form-label">Mot de passe</label>
            }
            else
            {
                <label for="Password" class="form-label">Mật khẩu</label>
            }
            <input type="password" class="form-control" id="Password" name="Password" required />
        </div>
        
        @if (lang == "en")
        {
            <button type="submit" class="btn btn-primary w-100">Login</button>
        }
        else if (lang == "fr")
        {
            <button type="submit" class="btn btn-primary w-100">Se connecter</button>
        }
        else
        {
            <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
        }
        
        <div class="text-center mt-3">
            @if (lang == "en")
            {
                <a href="/" class="text-decoration-none"><i class="fas fa-arrow-left"></i> Back to homepage</a>
            }
            else if (lang == "fr")
            {
                <a href="/" class="text-decoration-none"><i class="fas fa-arrow-left"></i> Retour à l'accueil</a>
            }
            else
            {
                <a href="/" class="text-decoration-none"><i class="fas fa-arrow-left"></i> Về trang chủ</a>
            }
        </div>
    </form>
</div>

</body>
</html>
