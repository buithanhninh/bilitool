@page "/admin/tai-khoan"
@using BiliTool.Vn.Application.Queries
@using BiliTool.Vn.Application.Commands
@using BiliTool.Vn.Application.DTOs
@using MediatR
@inject IMediator Mediator
@inject BiliTool.Vn.Web.Services.NguoiDungHienTaiService NguoiDung
@inject Blazored.Toast.Services.IToastService ToastService
@inject NavigationManager NavManager

<PageTitle>Quản lý Tài khoản — BiliTool.Vn Admin</PageTitle>

@if (isLoading)
{
    <div class="text-center my-4"><i class="fas fa-spinner fa-spin fa-2x"></i> Đang tải...</div>
}
else if (accounts != null)
{
    <div class="admin-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 style="font-weight: 800; color: var(--admin-text-main); margin-bottom:0;">
                    <i class="fas fa-users-cog text-primary"></i> Quản trị Y Bác sĩ
                </h2>
                <div class="text-muted mt-1">Quản lý toàn bộ danh sách tài khoản bác sĩ và người dùng hệ thống</div>
            </div>
            <a href="/admin" class="btn btn-light shadow-sm border"><i class="fas fa-arrow-left"></i> Về Dashboard</a>
        </div>

        <div class="premium-table-container">
            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Bác sĩ / Tổ chức</th>
                            <th>Liên hệ</th>
                            <th>Tương tác</th>
                            <th>Phân tích</th>
                            <th>Trạng thái</th>
                            <th style="width: 140px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in accounts)
                        {
                            var lastActiveDays = (DateTime.UtcNow - acc.NgayDangNhapCuoi).TotalDays;
                            var isOnline = lastActiveDays < 1;

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width: 40px; height: 40px; border-radius: 10px; background: var(--admin-primary-light); color: var(--admin-primary); display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem;">
                                            @(acc.HoTen.Length > 0 ? acc.HoTen[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div>
                                            <div style="font-weight: 600; color: var(--admin-text-main);">@acc.HoTen</div>
                                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">
                                                @if(!string.IsNullOrEmpty(acc.ChuyenKhoa)){ <text>@acc.ChuyenKhoa</text> } else { <text>Bác sĩ lâm sàng</text> }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size: 0.85rem;">
                                        <div class="text-muted"><i class="fas fa-envelope me-1"></i> @acc.Email</div>
                                        @if(!string.IsNullOrEmpty(acc.DonViCongTac)){ <div class="mt-1"><i class="fas fa-hospital me-1 text-primary"></i> @acc.DonViCongTac</div> }
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size: 0.85rem;">
                                        <div class="d-flex align-items-center gap-1">
                                            <div style="width:8px; height:8px; border-radius:50%; background:@(isOnline ? "var(--admin-success)" : "var(--admin-text-muted)");"></div>
                                            @(isOnline ? "Đang Active" : $"Offline {Math.Floor(lastActiveDays)} ngày")
                                        </div>
                                        <div class="text-muted mt-1" style="font-size: 0.75rem;">Tham gia: @acc.NgayTao.ToString("MM/yyyy")</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <span class="admin-badge badge-neutral"><i class="fas fa-baby text-info me-1"></i> @acc.TongBenhNhan hồ sơ</span>
                                        <span class="admin-badge badge-neutral"><i class="fas fa-calculator text-success me-1"></i> @acc.TinhToanTrong30NgayQua tính toán (30d)</span>
                                    </div>
                                </td>
                                <td>
                                    @if (acc.IsActive)
                                    {
                                        <span class="admin-badge badge-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge badge-danger">Bị khóa</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a href="/admin/tai-khoan/@acc.Id" class="btn btn-sm btn-light border" title="Xem chi tiết Analytic">
                                            <i class="fas fa-chart-line text-primary"></i>
                                        </a>
                                        @if (acc.IsActive)
                                        {
                                            <button class="btn btn-sm btn-light border" style="color: var(--admin-danger);" @onclick="() => ToggleLock(acc.Id, false, acc.HoTen)" title="Khóa ngay">
                                                <i class="fas fa-lock"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-light border" style="color: var(--admin-success);" @onclick="() => ToggleLock(acc.Id, true, acc.HoTen)" title="Mở khóa">
                                                <i class="fas fa-unlock"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<TaiKhoanAdminDto>? accounts;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!NguoiDung.DaDangNhap)
        {
            NavManager.NavigateTo("/admin/login", forceLoad: true);
            return;
        }

        if (!NguoiDung.LaQuanTriVien)
        {
            NavManager.NavigateTo("/");
            return;
        }

        await LoadData();
    }
    
    // ... rest of code unchanged
    
    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        accounts = await Mediator.Send(new GetDanhSachTaiKhoanQuery());
        isLoading = false;
        StateHasChanged();
    }

    private async Task ToggleLock(string id, bool newStatus, string name)
    {
        var result = await Mediator.Send(new KhoaTaiKhoanCommand(id, newStatus));
        if (result)
        {
            ToastService.ShowSuccess($"Đã {(newStatus ? "Mở khóa" : "Khóa")} tài khoản {name}.");
            await LoadData();
        }
        else
        {
            ToastService.ShowError("Có lỗi xảy ra, không tìm thấy tài khoản.");
        }
    }
}
