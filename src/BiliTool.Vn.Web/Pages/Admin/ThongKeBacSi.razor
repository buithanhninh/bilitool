@page "/admin/thong-ke/bac-si"
@using BiliTool.Vn.Application.Queries
@using BiliTool.Vn.Application.DTOs
@using MediatR
@inject IMediator Mediator
@inject BiliTool.Vn.Web.Services.NguoiDungHienTaiService NguoiDung
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Thống kê Bác sĩ — BiliTool.Vn Admin</PageTitle>

@if (data == null)
{
    <div class="text-center" style="margin: 80px;">
        <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
        <div class="mt-3 text-muted">Đang phân tích dữ liệu Bác sĩ...</div>
    </div>
}
else
{
    <div class="admin-container" style="max-width: 1600px;">

        <!-- ── HEADER ──────────────────────────────────────────────── -->
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <div class="mb-1">
                    <a href="/admin" class="btn btn-sm btn-light border px-2 py-1" style="font-size:0.78rem;">
                        <i class="fas fa-arrow-left"></i> Dashboard
                    </a>
                </div>
                <h2 style="font-weight: 800; color: var(--admin-text-main); margin-bottom: 2px; font-size:1.4rem;">
                    <i class="fas fa-user-md text-primary"></i> Thống kê Y Bác sĩ
                </h2>
                <div class="text-muted" style="font-size:0.8rem;">Phân tích toàn diện 14 chỉ số hành vi &amp; hiệu suất | Real-time @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <a href="/admin/tai-khoan" class="btn btn-sm btn-light border" style="font-size:0.8rem;">
                <i class="fas fa-users"></i> Danh sách BS
            </a>
        </div>

        <!-- ── KPI BAND: 10 chỉ số — compact strip ──────────────── -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 20px;">
            <div class="admin-card text-center py-2 px-2" style="min-height:unset;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">Tổng BS</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#4338ca;">@data.TongBacSi</div>
                <div style="font-size:0.7rem;color:#10b981;">+@data.BacSiMoiThangNay th.này</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">HĐ 7 ngày</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#10b981;">@data.BacSiHoatDong7Ngay</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">@(data.TongBacSi > 0 ? Math.Round(100.0 * data.BacSiHoatDong7Ngay / data.TongBacSi, 1) : 0)% tổng số</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">HĐ 30 ngày</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#0ea5e9;">@data.BacSiHoatDong30Ngay</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">bác sĩ</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset; border-top:3px solid #ef4444;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">Silent Churn</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#ef4444;">@data.BacSiInactive30Ngay</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">&gt;30 ngày không login</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">Avg BN/BS</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#8b5cf6;">@data.AvgBenhNhanPerBacSi</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">bệnh nhi / bác sĩ</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset; border-top:3px solid #f59e0b;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">T.Toán Vượt</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#f59e0b;">@data.TiLeTinhToanVuotNguong%</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">≠ Bình thường</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">Time-to-Value</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#0ea5e9;">@data.AvgNgayDenBenhNhanDauTien</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">ngày đến BN đầu tiên</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset; border-top:3px solid #ef4444;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">BS có BN Nguy cơ TK</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#ef4444;">@data.BacSiCoBenhNhiNguyCoThanKinh</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">bác sĩ cần chú ý</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset; border-top:3px solid #10b981;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">Hồ sơ Đầy đủ</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#10b981;">@data.BacSiDuHoSo</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">/ @data.TongBacSi bác sĩ</div>
            </div>
            <div class="admin-card text-center py-2 px-2" style="min-height:unset; border-top:3px solid #8b5cf6;">
                <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;color:var(--admin-text-muted);letter-spacing:.5px;">Avg T.Toán/BS/Th</div>
                <div style="font-size:1.9rem;font-weight:900;line-height:1.1;color:#8b5cf6;">@data.AvgLuotTinhToanPerBacSiPerThang</div>
                <div style="font-size:0.7rem;color:var(--admin-text-muted);">lượt/bs/tháng</div>
            </div>
        </div>

        <!-- ── SECTION A: Charts 3 cột ───────────────────────────── -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 16px; margin-bottom: 20px;">
            <div>
                <div class="admin-card h-100" style="padding:16px;">
                    <div class="kpi-title mb-2" style="font-size:0.8rem;">
                        <i class="fas fa-stethoscope text-primary"></i> Phân bố Chuyên khoa
                    </div>
                    <div style="height:230px;"><canvas id="chartChuyenKhoa"></canvas></div>
                </div>
            </div>
            <div>
                <div class="admin-card h-100" style="padding:16px;">
                    <div class="kpi-title mb-2" style="font-size:0.8rem;">
                        <i class="fas fa-hospital" style="color:#0ea5e9;"></i> Top Đơn vị Công tác
                    </div>
                    <div style="height:230px;"><canvas id="chartDonVi"></canvas></div>
                </div>
            </div>
            <div>
                <div class="admin-card h-100" style="padding:16px;">
                    <div class="kpi-title mb-2" style="font-size:0.8rem;">
                        <i class="fas fa-layer-group" style="color:#0ea5e9;"></i> Cường độ Sử dụng (30 ngày)
                    </div>
                    <div style="height:230px;"><canvas id="chartCuongDo"></canvas></div>
                </div>
            </div>
        </div>

        <!-- ── SECTION B: Onboarding trend full-width ─────────────── -->
        <div class="admin-card mb-3" style="padding:16px;">
            <div class="kpi-title mb-2" style="font-size:0.8rem;">
                <i class="fas fa-user-plus text-success"></i> Tốc độ Onboarding — Bác sĩ mới đăng ký (12 Tuần)
            </div>
            <div style="height:180px;"><canvas id="chartOnboarding"></canvas></div>
        </div>

        <!-- ── SECTION C: Leaderboard ────────────────────────────── -->
        <div class="admin-card" style="padding:16px;">
            <div class="kpi-title mb-3" style="font-size:0.85rem;">
                <i class="fas fa-trophy" style="color:#f59e0b;"></i> Leaderboard — Top 10 Bác sĩ Hoạt động Nhất
            </div>
            <div class="table-responsive">
                <table class="premium-table" style="font-size:0.82rem;">
                    <thead>
                        <tr>
                            <th style="width:36px;">#</th>
                            <th>Bác sĩ</th>
                            <th>Đơn vị / Chuyên khoa</th>
                            <th>Bệnh nhi</th>
                            <th>T.Toán 30 ngày</th>
                            <th>Tổng T.Toán</th>
                            <th>BN Nguy cơ TK</th>
                            <th>Login cuối</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var bs in data.Top10BacSiHoatDong)
                        {
                            <tr>
                                <td style="text-align:center;">
                                    @if (rank == 1) {<span style="font-size:1.1rem;">🥇</span>}
                                    else if (rank == 2) {<span style="font-size:1.1rem;">🥈</span>}
                                    else if (rank == 3) {<span style="font-size:1.1rem;">🥉</span>}
                                    else {<span class="text-muted fw-bold">@rank</span>}
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:30px;height:30px;border-radius:8px;background:var(--admin-primary-light);color:var(--admin-primary);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;flex-shrink:0;">
                                            @(bs.HoTen.Length > 0 ? bs.HoTen[0].ToString() : "?")
                                        </div>
                                        <div>
                                            <div style="font-weight:600;">@bs.HoTen</div>
                                            <div style="font-size:0.72rem;color:var(--admin-text-muted);">@bs.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size:0.78rem;">@(bs.DonViCongTac ?? "—")</div>
                                    <div class="meta-tag mt-1" style="font-size:0.7rem;">@(bs.ChuyenKhoa ?? "—")</div>
                                </td>
                                <td><span class="admin-badge badge-neutral" style="font-size:0.7rem;">@bs.SoBenhNhan BN</span></td>
                                <td><span class="admin-badge badge-success" style="font-size:0.7rem;">@bs.LuotTinhToan30Ngay lượt</span></td>
                                <td><strong>@bs.TongLuotTinhToan</strong></td>
                                <td>
                                    @if (bs.CoNguoiBenhNhiNguyCoThanKinh)
                                    {<span class="admin-badge badge-warning" style="font-size:0.7rem;"><i class="fas fa-exclamation-triangle"></i> Có</span>}
                                    else
                                    {<span class="admin-badge badge-neutral" style="font-size:0.7rem;">Không</span>}
                                </td>
                                <td><span class="text-muted" style="font-size:0.78rem;">@bs.NgayDangNhapCuoi.ToString("dd/MM/yy")</span></td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
}

@code {
    private ThongKeBacSiAdminDto? data;
    private bool chartsRendered = false;

    protected override async Task OnInitializedAsync()
    {
        if (!NguoiDung.DaDangNhap || !NguoiDung.LaQuanTriVien)
        {
            NavManager.NavigateTo("/admin/login", forceLoad: true);
            return;
        }
        data = await Mediator.Send(new GetThongKeBacSiQuery());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (data != null && !chartsRendered)
        {
            chartsRendered = true;
            await RenderCharts();
        }
    }

    private async Task RenderCharts()
    {
        if (data == null) return;

        await JS.InvokeVoidAsync("adminCharts.renderPieChart",
            "chartChuyenKhoa",
            data.PhanBoChuyenKhoa.Select(x => x.NhanNhom).ToArray(),
            data.PhanBoChuyenKhoa.Select(x => x.SoLuong).ToArray(),
            null);

        if (data.TopDonViCongTac.Any())
        {
            await JS.InvokeVoidAsync("adminCharts.renderHorizontalBar",
                "chartDonVi",
                data.TopDonViCongTac.Select(x => x.NhanNhom).ToArray(),
                data.TopDonViCongTac.Select(x => x.SoLuong).ToArray(),
                "#4338ca");
        }

        await JS.InvokeVoidAsync("adminCharts.renderHistogram",
            "chartCuongDo",
            data.PhanBoCuongDoSuDung.Select(x => x.NhanNhom).ToArray(),
            data.PhanBoCuongDoSuDung.Select(x => x.SoLuong).ToArray(),
            "#0ea5e9");

        await JS.InvokeVoidAsync("adminCharts.renderAreaChart",
            "chartOnboarding",
            data.OnboardingTuanQua.Select(x => x.Ngay).ToArray(),
            data.OnboardingTuanQua.Select(x => x.SoLuong).ToArray(),
            "#10b981",
            "Bác sĩ mới");
    }
}
