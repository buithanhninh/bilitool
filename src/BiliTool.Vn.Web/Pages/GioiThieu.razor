@page "/gioi-thieu"
@using System.Globalization

@{
    var lang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLowerInvariant();
    var isEnglish = lang == "en";
    var isFrench = lang == "fr";

    var pageTitle = isEnglish
        ? "About BiliTool.Vn — Medical Advisor ThS. BS. Ninh Thi Phuong Mai | E Hospital"
        : isFrench
            ? "À propos de BiliTool.Vn — Conseiller Médical Dr. Ninh Thi Phuong Mai | Hôpital E"
            : "Giới Thiệu BiliTool.Vn — Cố Vấn Chuyên Môn ThS. BS. Ninh Thị Phương Mai | Bệnh Viện E";

    var heroTitle = isEnglish ? "About BiliTool.Vn" : isFrench ? "À propos de BiliTool.Vn" : "Giới thiệu BiliTool.Vn";
    var heroLead = isEnglish
        ? "Clinical decision support software for neonatal jaundice management"
        : isFrench
            ? "Logiciel d’aide à la décision clinique pour la prise en charge de l’ictère néonatal"
            : "Phần mềm hỗ trợ lâm sàng quản lý vàng da sơ sinh";

    var overviewTitle = isEnglish ? "Clinical workflow, not a generic calculator" : isFrench ? "Flux clinique, pas seulement un calculateur" : "Quy trình lâm sàng, không chỉ là máy tính";
    var overviewBody1 = isEnglish
        ? "BiliTool.Vn is a web-based medical tool designed to support pediatricians, neonatologists, and healthcare professionals in assessment, monitoring, and treatment decision-making for neonatal jaundice."
        : isFrench
            ? "BiliTool.Vn est un outil médical web conçu pour aider les pédiatres, néonatologues et professionnels de santé dans l’évaluation, le suivi et la décision thérapeutique de l’ictère néonatal."
            : "BiliTool.Vn là công cụ y khoa dạng web hỗ trợ bác sĩ nhi khoa, bác sĩ sơ sinh và nhân viên y tế trong đánh giá, theo dõi và ra quyết định điều trị vàng da sơ sinh.";
    var overviewBody2 = isEnglish
        ? "The system combines age in hours, total serum bilirubin, gestational age, and neurotoxicity or clinical risk factors to calculate phototherapy and exchange transfusion thresholds, then presents results in a clear trend-oriented interface."
        : isFrench
            ? "Le système combine l’âge en heures, la bilirubine totale, l’âge gestationnel et les facteurs de risque pour calculer les seuils de photothérapie et d’exsanguino-transfusion, puis présente les résultats dans une interface orientée tendance."
            : "Hệ thống kết hợp giờ tuổi, bilirubin toàn phần, tuổi thai và các yếu tố nguy cơ thần kinh/lâm sàng để tính ngưỡng chiếu đèn, ngưỡng thay máu và trình bày kết quả theo hướng dễ theo dõi xu hướng.";

    var scienceTitle = isEnglish ? "Scientific basis" : isFrench ? "Base scientifique" : "Căn cứ khoa học";
    var scienceLead = isEnglish
        ? "Algorithms, configuration constants, and displayed recommendations are cross-referenced from two major clinical guidelines."
        : isFrench
            ? "Les algorithmes, constantes de configuration et recommandations affichées sont croisés à partir de deux recommandations cliniques majeures."
            : "Thuật toán, hằng số cấu hình và khuyến nghị hiển thị được đối chiếu từ hai phác đồ lâm sàng lớn.";
    var clinicalSupportBadge = isEnglish ? "Clinical Decision Support" : isFrench ? "Aide à la décision clinique" : "Hỗ trợ quyết định lâm sàng";
    var aapDate = isEnglish ? "Pediatrics, 09/2022" : isFrench ? "Pediatrics, 09/2022" : "Pediatrics, tháng 09/2022";
    var niceDate = isEnglish ? "Updated 10/2023" : isFrench ? "Mis à jour 10/2023" : "Cập nhật 10/2023";
    var aapReferenceTitle = isEnglish ? "Clinical Practice Guideline Revision" : isFrench ? "Révision des recommandations de pratique clinique" : "Clinical Practice Guideline Revision";
    var niceReferenceTitle = isEnglish ? "Jaundice in newborn babies under 28 days" : isFrench ? "Ictère chez les nouveau-nés de moins de 28 jours" : "Jaundice in newborn babies under 28 days";

    var advisorTitle = isEnglish ? "Author & Clinical Advisor" : isFrench ? "Autrice et conseillère clinique" : "Tác giả - Cố vấn chuyên môn";

    var advisorName = isEnglish ? "MSc. MD. Ninh Thi Phuong Mai" : isFrench ? "Dr. Ninh Thi Phuong Mai" : "ThS. BS. Ninh Thị Phương Mai";
    var metaDescription = isEnglish
        ? "BiliTool.Vn is clinical decision support software for neonatal jaundice management. Clinical advisor: MSc. MD. Ninh Thi Phuong Mai, General Pediatrics Department, E Hospital."
        : isFrench
            ? "BiliTool.Vn est un logiciel d’aide à la décision clinique pour la prise en charge de l’ictère néonatal. Conseillère clinique : Dr. Ninh Thi Phuong Mai, Hôpital E."
            : "BiliTool.Vn - phần mềm hỗ trợ lâm sàng quản lý vàng da sơ sinh tại Việt Nam. Cố vấn chuyên môn: ThS. BS. Ninh Thị Phương Mai - Khoa Nội Nhi Tổng Hợp, Bệnh viện E.";
    var metaKeywords = isEnglish
        ? "BiliTool.Vn, neonatal jaundice, bilirubin, Ninh Thi Phuong Mai, E Hospital, AAP 2022, NICE CG98"
        : isFrench
            ? "BiliTool.Vn, ictère néonatal, bilirubine, Ninh Thi Phuong Mai, Hôpital E, AAP 2022, NICE CG98"
            : "BiliTool.Vn, vàng da sơ sinh, bilirubin, ThS BS Ninh Thị Phương Mai, Bệnh viện E, AAP 2022, NICE CG98";
    var socialDescription = isEnglish
        ? "Clinical decision support for neonatal jaundice assessment and monitoring using AAP 2022 and NICE CG98."
        : isFrench
            ? "Aide à la décision clinique pour l’évaluation et le suivi de l’ictère néonatal selon AAP 2022 et NICE CG98."
            : "Phần mềm hỗ trợ lâm sàng quản lý vàng da sơ sinh. Cố vấn chuyên môn: ThS. BS. Ninh Thị Phương Mai — Bệnh viện E.";
    var hospital = isEnglish ? "General Pediatrics Department – E Hospital" : isFrench ? "Pédiatrie générale – Hôpital E" : "Khoa Nội Nhi Tổng Hợp – Bệnh viện E";
    var bio1 = isEnglish
        ? "ThS. BS. Ninh Thi Phuong Mai has years of direct clinical experience in pediatric examination and treatment, with strengths in respiratory disease, immunology-allergy, gastroenterology, and pediatric nutrition."
        : isFrench
            ? "Dr. Ninh Thi Phuong Mai possède plusieurs années d’expérience clinique directe en pédiatrie, notamment en pathologie respiratoire, immunologie-allergologie, gastroentérologie et nutrition pédiatrique."
            : "ThS. BS. Ninh Thị Phương Mai có nhiều năm kinh nghiệm trực tiếp thăm khám và điều trị bệnh lý chuyên khoa Nhi, đặc biệt trong hô hấp, miễn dịch – dị ứng, tiêu hóa và dinh dưỡng trẻ em.";
    var bio2 = isEnglish
        ? "She contributes to medical translation, algorithm digitization, and clinical workflow review so BiliTool.Vn can serve as a practical support tool for the healthcare community."
        : isFrench
            ? "Elle participe à la traduction médicale, à la numérisation de l’algorithme et à la revue du flux clinique afin que BiliTool.Vn devienne un outil pratique pour la communauté soignante."
            : "Bác sĩ tham gia biên dịch, số hóa thuật toán y khoa và cố vấn quy trình vận hành lâm sàng thực tế để BiliTool.Vn trở thành công cụ hỗ trợ thiết thực cho cộng đồng y tế.";

    var trainingTitle = isEnglish ? "Training" : isFrench ? "Formation" : "Đào tạo";
    var activityTitle = isEnglish ? "Professional work" : isFrench ? "Activité professionnelle" : "Hoạt động chuyên môn";
    var websiteLabel = isEnglish ? "Visit DrNinhMai.Com" : isFrench ? "Visiter DrNinhMai.Com" : "Ghé thăm DrNinhMai.Com";

    var trainingItems = isEnglish
        ? new[] { "General Practitioner, Hanoi Medical University (2017)", "Pediatric Orientation, Vietnam National Children’s Hospital (2018)", "Master of Pediatrics, Hanoi Medical University (2024)" }
        : isFrench
            ? new[] { "Médecin généraliste, Université médicale de Hanoï (2017)", "Orientation pédiatrique, Hôpital national pédiatrique (2018)", "Master de pédiatrie, Université médicale de Hanoï (2024)" }
            : new[] { "Tốt nghiệp Bác sĩ Đa khoa - Đại học Y Hà Nội (2017)", "Bác sĩ Định hướng Nhi - Bệnh viện Nhi Trung ương (2018)", "Thạc sĩ chuyên ngành Nhi khoa - Đại học Y Hà Nội (2024)" };

    var activityItems = isEnglish
        ? new[] { "Works at E Hospital (2018–present)", "Author of multiple pediatric specialty studies", "Received Certificate of Merit from the Ministry of Health (2024)" }
        : isFrench
            ? new[] { "Exerce à l’Hôpital E (2018 à ce jour)", "Autrice de plusieurs études spécialisées en pédiatrie", "Certificat de mérite du ministère de la Santé (2024)" }
            : new[] { "Công tác tại Bệnh viện E (2018–nay)", "Tác giả nhiều nghiên cứu chuyên ngành Nhi khoa", "Nhận Bằng khen của Bộ Y tế (2024)" };
}

<PageTitle>@pageTitle</PageTitle>

<HeadContent>
    <meta name="description" content="@metaDescription" />
    <meta name="keywords" content="@metaKeywords" />
    <SeoLanguageLinks Path="/gioi-thieu" />
    <MedicalAuthoritySchema PageType="AboutPage" Path="/gioi-thieu" Language="@lang" Title="@pageTitle" Description="@metaDescription" />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@socialDescription" />
    <meta property="og:url" content="https://bilitool.vn/gioi-thieu" />
    <meta property="og:site_name" content="BiliTool.Vn" />
    <meta property="og:image" content="https://bilitool.vn/images/og-bilitool-1200x630.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@pageTitle" />
    <meta name="twitter:description" content="@socialDescription" />
</HeadContent>

<div class="about-page-shell">
    <section class="about-hero-panel">
        <div class="about-hero-orb about-hero-orb-one" aria-hidden="true"></div>
        <div class="about-hero-orb about-hero-orb-two" aria-hidden="true"></div>
        <div class="about-kicker"><i class="fas fa-stethoscope"></i> BiliTool.Vn</div>
        <h1>@heroTitle</h1>
        <p>@heroLead</p>
        <div class="about-hero-badges" aria-label="Clinical references">
            <span><i class="fas fa-shield-alt"></i> AAP 2022</span>
            <span><i class="fas fa-book-medical"></i> NICE CG98</span>
            <span><i class="fas fa-chart-line"></i> @clinicalSupportBadge</span>
        </div>
    </section>

    <section class="about-grid about-reveal">
        <article class="about-card about-card-large">
            <div class="about-section-label"><i class="fas fa-laptop-medical"></i> @overviewTitle</div>
            <p>@overviewBody1</p>
            <p>@overviewBody2</p>
            <div class="about-metric-strip">
                <div><strong>35+</strong><span>@(isEnglish ? "weeks GA" : isFrench ? "semaines AG" : "tuần tuổi thai")</span></div>
                <div><strong>28</strong><span>@(isEnglish ? "days window" : isFrench ? "jours suivis" : "ngày theo dõi")</span></div>
                <div><strong>2</strong><span>@(isEnglish ? "protocols" : isFrench ? "protocoles" : "phác đồ")</span></div>
            </div>
        </article>

        <article class="about-card about-science-card">
            <div class="about-section-label"><i class="fas fa-flask"></i> @scienceTitle</div>
            <p>@scienceLead</p>
            <div class="about-reference-list">
                <a href="https://publications.aap.org/pediatrics/article/150/3/e2022058859/188726/Clinical-Practice-Guideline-Revision-Management-of" target="_blank" rel="noopener">
                    <span>AAP 2022</span>
                    <strong>@aapReferenceTitle</strong>
                    <small>@aapDate</small>
                </a>
                <a href="https://www.nice.org.uk/guidance/cg98" target="_blank" rel="noopener">
                    <span>NICE CG98</span>
                    <strong>@niceReferenceTitle</strong>
                    <small>@niceDate</small>
                </a>
            </div>
        </article>
    </section>

    <section class="about-advisor-panel about-reveal">
        <div class="about-advisor-photo">
            <img src="/images/bs-mai.jpg" alt="@advisorName" onerror="this.src='/images/doctor-placeholder.svg'" />
        </div>
        <div class="about-advisor-content">
            <div class="about-section-label"><i class="fas fa-user-md"></i> @advisorTitle</div>
            <h2>@advisorName</h2>
            <p class="about-advisor-role"><i class="fas fa-hospital"></i> @hospital</p>
            <p>@bio1</p>
            <p>@bio2</p>
            <a class="about-primary-link" href="https://drninhmai.com/" target="_blank" rel="noopener">
                <i class="fas fa-globe"></i> @websiteLabel
            </a>
        </div>
    </section>

    <section class="about-credentials-grid about-reveal">
        <article class="about-card about-list-card">
            <div class="about-section-label"><i class="fas fa-graduation-cap"></i> @trainingTitle</div>
            <ul>
                @foreach (var item in trainingItems)
                {
                    <li><i class="fas fa-check"></i><span>@item</span></li>
                }
            </ul>
        </article>
        <article class="about-card about-list-card">
            <div class="about-section-label"><i class="fas fa-award"></i> @activityTitle</div>
            <ul>
                @foreach (var item in activityItems)
                {
                    <li><i class="fas fa-check"></i><span>@item</span></li>
                }
            </ul>
        </article>
    </section>
</div>

<style>
    .about-page-shell {
        --about-ink: #07111f;
        --about-muted: #526070;
        --about-soft: #eef7fb;
        --about-line: rgba(15, 95, 143, 0.16);
        --about-primary: #0f5f8f;
        --about-teal: #0f766e;
        --about-green: #17693a;
        max-width: 1180px;
        margin: 0 auto;
        padding: clamp(18px, 3vw, 34px);
        color: var(--about-ink);
        font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
    }

    .about-hero-panel,
    .about-card,
    .about-advisor-panel {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.72);
        background: linear-gradient(145deg, rgba(255,255,255,0.94), rgba(248,252,255,0.82));
        box-shadow: 0 24px 70px rgba(8, 34, 55, 0.11), inset 0 1px 0 rgba(255,255,255,0.9);
        backdrop-filter: blur(18px);
    }

    .about-hero-panel {
        min-height: 320px;
        border-radius: 34px;
        padding: clamp(34px, 6vw, 76px);
        isolation: isolate;
        background:
            radial-gradient(circle at 12% 18%, rgba(15, 118, 110, 0.18), transparent 28%),
            radial-gradient(circle at 92% 12%, rgba(15, 95, 143, 0.20), transparent 30%),
            linear-gradient(135deg, rgba(255,255,255,0.98), rgba(235,248,255,0.88));
    }

    .about-hero-panel::after {
        content: "";
        position: absolute;
        inset: auto -12% -42% 38%;
        height: 260px;
        background: linear-gradient(90deg, rgba(15, 95, 143, 0.10), rgba(15, 118, 110, 0.08));
        transform: rotate(-8deg);
        border-radius: 999px;
        z-index: -1;
    }

    .about-hero-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(2px);
        opacity: 0.58;
        animation: aboutFloat 8s ease-in-out infinite;
        z-index: -1;
    }

    .about-hero-orb-one {
        width: 180px;
        height: 180px;
        right: 10%;
        top: 16%;
        background: radial-gradient(circle, rgba(15,95,143,0.28), transparent 68%);
    }

    .about-hero-orb-two {
        width: 130px;
        height: 130px;
        left: 9%;
        bottom: 12%;
        background: radial-gradient(circle, rgba(23,105,58,0.18), transparent 70%);
        animation-delay: -2.5s;
    }

    .about-kicker,
    .about-section-label {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        color: var(--about-primary);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .about-hero-panel h1 {
        max-width: 760px;
        margin: 16px 0 14px;
        color: var(--about-ink);
        font-size: clamp(2.35rem, 6vw, 4.9rem);
        line-height: 0.96;
        letter-spacing: -0.065em;
        font-weight: 900;
        outline: none !important;
        border: 0 !important;
    }

    .about-hero-panel p {
        max-width: 650px;
        margin: 0;
        color: var(--about-muted);
        font-size: clamp(1.04rem, 2vw, 1.28rem);
        line-height: 1.72;
        font-weight: 500;
    }

    .about-hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 28px;
    }

    .about-hero-badges span,
    .about-primary-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 999px;
        border: 1px solid rgba(15,95,143,0.14);
        background: rgba(255,255,255,0.76);
        color: var(--about-primary);
        font-weight: 800;
        font-size: 0.9rem;
        padding: 10px 14px;
        box-shadow: 0 10px 24px rgba(8,34,55,0.07);
    }

    .about-grid,
    .about-credentials-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
        gap: 20px;
        margin-top: 22px;
    }

    .about-card,
    .about-advisor-panel {
        border-radius: 28px;
        padding: clamp(24px, 4vw, 38px);
    }

    .about-card p,
    .about-advisor-content p {
        color: var(--about-muted);
        font-size: 1.02rem;
        line-height: 1.78;
        margin: 14px 0 0;
    }

    .about-metric-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 26px;
    }

    .about-metric-strip div {
        border: 1px solid var(--about-line);
        border-radius: 20px;
        padding: 16px;
        background: linear-gradient(180deg, rgba(240,249,255,0.9), rgba(255,255,255,0.7));
    }

    .about-metric-strip strong {
        display: block;
        color: var(--about-primary);
        font-size: 1.65rem;
        line-height: 1;
        letter-spacing: -0.04em;
    }

    .about-metric-strip span {
        display: block;
        margin-top: 7px;
        color: var(--about-muted);
        font-size: 0.82rem;
        font-weight: 700;
    }

    .about-reference-list {
        display: grid;
        gap: 12px;
        margin-top: 18px;
    }

    .about-reference-list a {
        display: grid;
        gap: 4px;
        padding: 16px;
        border-radius: 20px;
        border: 1px solid var(--about-line);
        color: var(--about-ink);
        text-decoration: none;
        background: rgba(255,255,255,0.7);
        transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
    }

    .about-reference-list a:hover,
    .about-primary-link:hover {
        transform: translateY(-3px);
        border-color: rgba(15,95,143,0.32);
        box-shadow: 0 18px 34px rgba(8,34,55,0.12);
        text-decoration: none;
    }

    .about-reference-list span {
        color: var(--about-teal);
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
    }

    .about-reference-list strong {
        font-size: 0.98rem;
        line-height: 1.35;
    }

    .about-reference-list small {
        color: var(--about-muted);
        font-weight: 700;
    }

    .about-advisor-panel {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        gap: clamp(22px, 4vw, 44px);
        align-items: center;
        margin-top: 22px;
        background:
            linear-gradient(135deg, rgba(7,17,31,0.96), rgba(9,55,82,0.93)),
            radial-gradient(circle at 78% 18%, rgba(45,212,191,0.22), transparent 34%);
        color: #ffffff;
    }

    .about-advisor-photo {
        position: relative;
        width: min(100%, 240px);
        aspect-ratio: 1;
        margin: 0 auto;
        border-radius: 34px;
        padding: 10px;
        background: linear-gradient(145deg, rgba(255,255,255,0.34), rgba(255,255,255,0.08));
        box-shadow: 0 24px 54px rgba(0,0,0,0.28);
    }

    .about-advisor-photo::after {
        content: "";
        position: absolute;
        inset: -8px;
        border-radius: 40px;
        border: 1px solid rgba(255,255,255,0.18);
        pointer-events: none;
    }

    .about-advisor-photo img {
        width: 100%;
        height: 100%;
        border-radius: 26px;
        object-fit: cover;
        display: block;
    }

    .about-advisor-content .about-section-label,
    .about-advisor-content .about-advisor-role {
        color: #8ee6dc;
    }

    .about-advisor-content h2 {
        margin: 12px 0 8px;
        color: #ffffff;
        font-size: clamp(1.75rem, 4vw, 3rem);
        line-height: 1.04;
        letter-spacing: -0.045em;
        font-weight: 900;
    }

    .about-advisor-content p {
        color: rgba(255,255,255,0.80);
    }

    .about-advisor-role {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 0 !important;
        font-weight: 800;
    }

    .about-primary-link {
        margin-top: 22px;
        background: linear-gradient(135deg, #ffffff, #e8fbff);
        color: #0a4f78;
        text-decoration: none;
    }

    .about-list-card ul {
        list-style: none;
        padding: 0;
        margin: 20px 0 0;
        display: grid;
        gap: 12px;
    }

    .about-list-card li {
        display: grid;
        grid-template-columns: 26px 1fr;
        align-items: start;
        gap: 10px;
        color: var(--about-muted);
        font-weight: 650;
        line-height: 1.5;
    }

    .about-list-card li i {
        display: inline-grid;
        place-items: center;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: rgba(15,118,110,0.12);
        color: var(--about-green);
        font-size: 0.75rem;
    }

    .about-reveal {
        animation: aboutRise 520ms ease both;
    }

    .about-reveal:nth-of-type(3) {
        animation-delay: 80ms;
    }

    .about-reveal:nth-of-type(4) {
        animation-delay: 140ms;
    }

    @@keyframes aboutRise {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes aboutFloat {
        0%, 100% { transform: translate3d(0, 0, 0); }
        50% { transform: translate3d(0, -12px, 0); }
