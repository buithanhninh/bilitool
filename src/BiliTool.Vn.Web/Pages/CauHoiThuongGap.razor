    {
        "@@context": "https://schema.org",
        "@@type": "FAQPage",
        "mainEntity": [
            {
                "@@type": "Question",
                "name": "BiliTool.Vn sử dụng dữ liệu tham chiếu từ đâu?",
                "acceptedAnswer": {
                    "@@type": "Answer",
                    "text": "BiliTool.Vn được xây dựng dựa trên Hướng dẫn thực hành lâm sàng của Viện Hàn lâm Nhi khoa Hoa Kỳ (AAP) cập nhật năm 2022 kết hợp NICE CG98, sử dụng thuật toán nội suy phương trình bậc 3."
                }
            },
            {
                "@@type": "Question",
