@page "/tich-hop-his"
@using System.Globalization

@{
    var lang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLower();
}

@if (lang == "en")
{
    <PageTitle>HIS / EMR Integration — BiliTool.Vn API & Deep Link</PageTitle>

    <HeadContent>
        <meta name="description" content="Technical reference for integrating BiliTool.Vn with hospital management systems (HIS) and electronic medical records (EMR). Supports Deep Linking (URL parameters) and RESTful API." />
        <meta name="keywords" content="HIS integration, EMR integration, bilirubin API, deep link bilitool, hospital software, automated bilirubin calculation" />
        <link rel="canonical" href="https://bilitool.vn/tich-hop-his" />
        <meta property="og:type" content="article" />
        <meta property="og:title" content="BiliTool.Vn Hospital HIS/EMR Integration" />
        <meta property="og:description" content="API and Deep Link guidelines for integrating neonatal bilirubin calculations into hospital software." />
        <meta property="og:url" content="https://bilitool.vn/tich-hop-his" />
        <meta property="og:site_name" content="BiliTool.Vn" />
        <meta property="og:image" content="https://bilitool.vn/images/og-bilitool.png" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="BiliTool.Vn Hospital HIS/EMR Integration" />
        <meta name="twitter:description" content="Integrate BiliTool's neonatal bilirubin calculator with your hospital EMR using APIs." />
    </HeadContent>

    <div class="his-integration-wrapper">
        <div class="his-header">
            <i class="fas fa-hospital-alt"></i>
            <h1>HIS / EMR System Integration</h1>
            <p>BiliTool.Vn provides flexible integration into existing Hospital Information Systems (HIS) or Electronic Medical Records (EMR) through 2 standardized methods.</p>
        </div>

        <div class="integration-method">
            <h2><span class="method-badge">Method 1</span> Deep Link (URL Parameters)</h2>
            <p>This is the simplest method, allowing the EMR to open BiliTool.Vn in a browser tab and pre-fill the newborn's clinical details via URL parameters. The clinician can review the information and click <strong>Calculate</strong>.</p>
            
            <div class="api-endpoint">
                <code>GET</code>
                <span class="url">https://bilitool.vn/may-tinh?ngaysinh={dd/mm/yyyy}&amp;giosinh={HH:mm}...</span>
            </div>

            <div class="table-responsive">
                <table class="table-api">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Example</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>ngaysinh</code></td>
                            <td>String</td>
                            <td>Date of birth (format: dd/mm/yyyy)</td>
                            <td><code>15/03/2026</code></td>
                        </tr>
                        <tr>
                            <td><code>giosinh</code></td>
                            <td>String</td>
                            <td>Time of birth (format: HH:mm)</td>
                            <td><code>08:30</code></td>
                        </tr>
                        <tr>
                            <td><code>ngaymau</code></td>
                            <td>String</td>
                            <td>Blood sample date (format: dd/mm/yyyy)</td>
                            <td><code>16/03/2026</code></td>
                        </tr>
                        <tr>
                            <td><code>giomau</code></td>
                            <td>String</td>
                            <td>Blood sample time (format: HH:mm)</td>
                            <td><code>10:00</code></td>
                        </tr>
                        <tr>
                            <td><code>bili</code></td>
                            <td>Number</td>
                            <td>Total Serum Bilirubin level</td>
                            <td><code>12.5</code></td>
                        </tr>
                        <tr>
                            <td><code>donvi</code></td>
                            <td>String</td>
                            <td>Measurement unit (<code>MgDl</code> or <code>UmolL</code>)</td>
                            <td><code>MgDl</code></td>
                        </tr>
                        <tr>
                            <td><code>tuoithai</code></td>
                            <td>Number</td>
                            <td>Gestational age in weeks (35 to 42)</td>
                            <td><code>38</code></td>
                        </tr>
                        <tr>
                            <td><code>autocalc</code></td>
                            <td>Boolean</td>
                            <td>Automatically trigger calculation on load (true/false)</td>
                            <td><code>true</code></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="code-example-box">
                <div class="code-header">
                    <span>Example: Opening BiliTool.Vn from EMR UI</span>
                </div>
                <pre><code>// JavaScript EMR Integration
const url = new URL("https://bilitool.vn/may-tinh");
url.searchParams.append("ngaysinh", "15/03/2026");
url.searchParams.append("giosinh", "08:30");
url.searchParams.append("ngaymau", "16/03/2026");
url.searchParams.append("giomau", "10:00");
url.searchParams.append("bili", "12.5");
url.searchParams.append("donvi", "MgDl");
url.searchParams.append("tuoithai", "38");
url.searchParams.append("autocalc", "true");

window.open(url.toString(), "_blank", "width=1200,height=800");</code></pre>
            </div>
        </div>

        <div class="integration-method">
            <h2><span class="method-badge">Method 2</span> RESTful API (Headless Call)</h2>
            <p>Allows EMR backend systems to post clinical data directly to the BiliTool.Vn calculations server. The server returns a structured JSON payload detailing all calculated AAP 2022 and NICE CG98 thresholds, risk assessments, and clinical follow-up recommendations for automatic storage and display in your EMR UI.</p>
            
            <p><strong>Security Token:</strong> To protect clinical calculations, all requests must contain the <code>X-API-Key</code> header containing the integration token configured for your hospital.</p>

            <div class="api-endpoint">
                <code>POST</code>
                <span class="url">/api/v1/bilirubin/calculate</span>
                <span class="content-type">Header: <code>X-API-Key: {your_api_key}</code></span>
            </div>

            <div class="code-example-box">
                <div class="code-header">
                    <span>Example: JSON Request Payload</span>
                </div>
                <pre><code>{
  "ngaySinh": "2026-03-15T08:30:00Z", // ISO 8601 UTC date-time string
  "ngayLayMau": "2026-03-16T10:00:00Z",
  "tongBilirubin": 12.5,
  "donViDo": 0, // 0 = MgDl, 1 = UmolL
  "tuoiThaiTuan": 38,
  "yeuToNguyCo": {
    "benhTanHuyetMienDichHoacThieuG6PD": false,
    "nhiemKhuanHuyetHoacNghiNgo": false,
    "albuminThapDuoi3gDl": false,
    "tinhTrangLamSangKhongOnDinh": false,
    "etCOcPpm": null,
    "anhChiBiVangDaCanChieuDen": false,
    "meBuMeHoanToan": false,
    "vangDaTrong24hDau": false,
    "benhTanHuyetRh": false,
    "benhTanHuyetABO": false,
    "dauHieuBenhNaoBilirubinCap": false
  },
  "trangThaiChieuDen": 0 // 0 = None, 1 = Standard, 2 = Intensive, 3 = Stopped (rebound check)
}</code></pre>
            </div>

            <div class="code-example-box">
                <div class="code-header">
                    <span>Example: JSON Response Payload</span>
                </div>
                <pre><code>{
  "tuoiGio": 25.5,
  "tuoiThaiTuan": 38,
  "bilirubinMgDl": 12.5,
  "bilirubinUmolL": 214.0,
  "coNguyCoThanKinh": false,
  "nguongChieuDen": 11.5,
  "nguongChieuDenTichCuc": 13.5,
  "nguongThayCuuMau": 21.4,
  "khoangCachDenNguongChieuDen": 1.0,
  "khoangCachDenNguongThayCuuMau": 8.9,
  "nguongChieuDen_NICE_UmolL": 300.0,
  "nguongThayCuuMau_NICE_UmolL": 450.0,
  "nguongChieuDen_NICE_MgDl": 17.5,
  "nguongThayCuuMau_NICE_MgDl": 26.3,
  "canChieuDenNgay": true,
  "canChieuDenTichCuc": false,
  "canXemXetThayCuuMau": false,
  "mucDoNguyHiemEnum": 2, // 0=Normal, 1=CloseMonitor, 2=NeedsPhototherapy, 3=NeedsIntensivePhoto, 4=ConsiderExchange, 5=EmergencyExchange
  "mauNguyHiem": "#e67e22",
  "thoiGianTaiKhamEnum": 2, // 0=Within4h, 1=Within8h, 2=Within12h, 3=Within24h
  "phacDoQuyetDinh": 0, // 0=AAP2022, 1=NICE_CG98
  "nguyCoKernicterus": false,
  "lyDoNguyCoKernicterus": [],
  "laVangDaKeoDai": false,
  "canhBaoVangDaKeoDai": null,
  "canIVIG": false,
  "moTaIVIG": null,
  "coTheDungChieuDen": false,
  "canKiemTraRebound": false,
  "lichDoLapNICE": "Below threshold >50 µmol/L — routine repeat not required (NICE 1.4.2)",
  "gioDoLapTiepTheo": null,
  "chuThichThamChieu": [
    "Phototherapy threshold per AAP 2022 (GA 38w, no neuro risk)",
    "Note: Clinical variation may exist among lab kits..."
  ],
  "thoiGianTinhToan": "2026-06-01T09:50:00Z"
}</code></pre>
            </div>
        </div>
    </div>
}
else if (lang == "fr")
{
    <PageTitle>Intégration HIS / EMR — API & Deep Link BiliTool.Vn</PageTitle>

    <HeadContent>
        <meta name="description" content="Référence technique pour l'intégration de BiliTool.Vn avec les dossiers de santé (HIS) et dossiers patients informatisés (EMR). Supporte le Deep Link et les API RESTful." />
        <meta name="keywords" content="Intégration HIS, intégration EMR, API bilirubine, deep link bilitool, logiciel hôpital, calcul automatique de la bilirubine" />
        <link rel="canonical" href="https://bilitool.vn/tich-hop-his" />
        <meta property="og:type" content="article" />
        <meta property="og:title" content="Intégration HIS/EMR BiliTool.Vn" />
        <meta property="og:description" content="Guide technique pour intégrer les calculs de bilirubine néonatale dans les progiciels de santé." />
        <meta property="og:url" content="https://bilitool.vn/tich-hop-his" />
        <meta property="og:site_name" content="BiliTool.Vn" />
