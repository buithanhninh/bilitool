  "mauNguyHiem": "#e67e22",
  "thoiGianTaiKhamEnum": 2, // 0=Sous4h, 1=Sous8h, 2=Sous12h, 3=Sous24h
  "phacDoQuyetDinh": 0, // 0=AAP2022, 1=NICE_CG98
