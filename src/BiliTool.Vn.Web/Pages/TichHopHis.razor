                            <th>Tham số</th>
                            <th>Loại</th>
                            <th>Mô tả</th>
                            <th>Ví dụ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>ngaysinh</code></td>
                            <td>String</td>
                            <td>Ngày sinh (định dạng: dd/mm/yyyy)</td>
                            <td><code>15/03/2026</code></td>
                        </tr>
                        <tr>
                            <td><code>giosinh</code></td>
                            <td>String</td>
                            <td>Giờ sinh (định dạng: HH:mm)</td>
                            <td><code>08:30</code></td>
                        </tr>
                        <tr>
                            <td><code>ngaymau</code></td>
                            <td>String</td>
                            <td>Ngày lấy mẫu máu</td>
                            <td><code>16/03/2026</code></td>
                        </tr>
                        <tr>
                            <td><code>giomau</code></td>
                            <td>String</td>
                            <td>Giờ lấy mẫu máu</td>
                            <td><code>10:00</code></td>
                        </tr>
                        <tr>
                            <td><code>bili</code></td>
                            <td>Number</td>
                            <td>Chỉ số Bilirubin toàn phần</td>
                            <td><code>12.5</code></td>
                        </tr>
                        <tr>
                            <td><code>donvi</code></td>
                            <td>String</td>
                            <td>Đơn vị đo (<code>MgDl</code> hoặc <code>UmolL</code>)</td>
                            <td><code>MgDl</code></td>
                        </tr>
                        <tr>
                            <td><code>tuoithai</code></td>
                            <td>Number</td>
                            <td>Tuổi thai (tuần). Từ 35 đến 45.</td>
                            <td><code>38</code></td>
                        </tr>
                        <tr>
                            <td><code>autocalc</code></td>
                            <td>Boolean</td>
                            <td>Tự động tính toán khi mở trang (true/false)</td>
