@page "/lich-su"
@using BiliTool.Vn.Domain.Entities
@using BiliTool.Vn.Application.Commands
@using BiliTool.Vn.Web.Services
@using MediatR
@inject IMediator Mediator
@inject IToastService Toast
@inject PhienLamViecService PhienLamViec
@inject IJSRuntime JS
@inject BiliTool.Vn.Web.Services.TranslationService T

<PageTitle>@T["Menu_History"]</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<div class="lich-su-wrapper">
    <div class="ls-header">
        <div class="ls-title">
            <i class="fas fa-history"></i>
            <h1>@T["Menu_History"]</h1>
        </div>
        @if (hoanTatTai && lichSuTinhToan.Any())
        {
            <button class="btn-clear" @onclick="ThongBaoXoa" title="@T["ClearHistory"]">
                <i class="fas fa-trash-alt"></i> @T["ClearHistory"]
            </button>
        }
    </div>

    @if (!hoanTatTai)
    {
        <div class="ls-loading">
            <i class="fas fa-spinner fa-spin"></i>
            <p>@T["Loading"]</p>
        </div>
    }
    else if (!lichSuTinhToan.Any())
    {
        <div class="ls-empty">
            <i class="fas fa-box-open"></i>
            <p>@T["History_Empty"]</p>
            <a href="/may-tinh" class="btn-to-calc">@T["History_GoToCalc"]</a>
        </div>
    }
    else
    {
        <div class="ls-cards">
            @foreach (var (item, index) in lichSuTinhToan.Select((v, i) => (v, i)))
            {
                <div class="ls-card">
                    <div class="ls-card-header">
                        <span class="ls-time">
                            <i class="far fa-clock"></i> 
                            @item.NgayTinhToan.ToString("dd/MM/yyyy HH:mm")
                        </span>
                        <span class="ls-badge @GetBadgeClass(item.MucDoNguyHiem)">
                            @GetTranslatedMucDo(item.MucDoNguyHiem)
                        </span>
                    </div>
                    
                    <div class="ls-card-body">
                        <div class="ls-stat-row">
                            <div class="ls-stat">
                                <small>@T["Age"]</small>
                                <strong>@string.Format(T["Age_Hours"], item.TuoiGio)</strong>
                                <span class="ls-note">(@item.TuoiThaiTuan @T["Weeks_Short"])</span>
                            </div>
                            <div class="ls-stat">
                                <small>@T["TotalBilirubin"]</small>
                                <strong>@item.BilirubinMgDl.ToString("0.#") <span class="ls-unit">mg/dL</span></strong>
                            </div>
                        </div>
 
                        <div class="ls-thresholds">
                            <div class="ls-th-item">
                                <i class="fas fa-lightbulb" style="color: #e67e22;"></i>
                                @T["Threshold_ChieuDen_Short"] <strong>@item.NguongChieuDen.ToString("0.#")</strong>
                            </div>
                            <div class="ls-th-item">
                                <i class="fas fa-sync" style="color: #c0392b;"></i>
                                @T["Threshold_ThayMau_Short"] <strong>@item.NguongThayCuuMau.ToString("0.#")</strong>
                            </div>
                        </div>
 
                        <div class="ls-recommendation">
                            @item.KhuyenNghiChinh
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool hoanTatTai = false;
    private List<LichSuTinhToan> lichSuTinhToan = new();
    private PhienLamViec? phienHienTai;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDataAsync();
            hoanTatTai = true;
            StateHasChanged();
        }
    }

    private async Task LoadDataAsync()
    {
        phienHienTai = await PhienLamViec.LayChiTietPhienAsync();
        if (phienHienTai != null && phienHienTai.LichSuTinhToan != null)
        {
            lichSuTinhToan = phienHienTai.LichSuTinhToan.OrderByDescending(x => x.NgayTinhToan).ToList();
        }
        else
        {
            lichSuTinhToan = new();
        }
    }

    private async Task ThongBaoXoa()
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa toàn bộ lịch sử trong phiên này?");
        if (confirm && phienHienTai != null)
        {
            try
            {
                var result = await Mediator.Send(new XoaLichSuCommand(phienHienTai.Id));
                if (result)
                {
                    Toast.ShowSuccess("Đã xóa lịch sử tính toán!");
                    await LoadDataAsync();
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Lỗi khi xóa: {ex.Message}");
            }
        }
    }

    private string GetBadgeClass(string mucDo) => mucDo switch
    {
        "BinhThuong" => "badge-normal",
        "CanTheoDoiSat" => "badge-warning",
        "CanChieuDen" => "badge-orange",
        "CanChieuDenTichCuc" => "badge-red",
        "CanXemXetThayMau" => "badge-darkred",
        "KhanCapThayCuuMau" => "badge-critical",
        // Fallback cho dữ liệu cũ (đã lưu cứng tiếng Việt)
        "Bình thường" => "badge-normal",
        "Cần theo dõi sát" => "badge-warning",
        "Cần chiếu đèn" => "badge-orange",
        "Cần chiếu đèn tích cực" => "badge-red",
        "Cân nhắc thay máu" => "badge-darkred",
        "KHẨN CẤP - Thay máu" => "badge-critical",
        _ => "badge-gray"
    };

    private string GetTranslatedMucDo(string mucDo)
    {
        // Thử tìm theo Key mới, nếu không thấy thì trả về nguyên bản (Fallback cũ)
        var translated = T[$"MucDo_{mucDo}"];
        return translated == $"MucDo_{mucDo}" ? mucDo : translated;
    }
}
