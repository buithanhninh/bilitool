@page "/dat-lai-mat-khau"
@model BiliTool.Vn.Web.Pages.DatLaiMatKhauModel
@{
    var lang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName.ToLower();
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (lang == "en")
    {
        <title>Reset Password — BiliTool.Vn</title>
    }
    else if (lang == "fr")
    {
        <title>Réinitialiser le mot de passe — BiliTool.Vn</title>
    }
    else
    {
        <title>Đặt lại mật khẩu — BiliTool.Vn</title>
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Be Vietnam Pro', sans-serif; background: #f0f4f8; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .login-card { background: white; border-radius: 20px; padding: 48px 40px; max-width: 460px; width: 100%; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.12); }
        .logo { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 28px; }
        .logo i { font-size: 2rem; color: #1a6b9a; }
        .logo span { font-size: 1.6rem; font-weight: 700; color: #1a263a; }
        h1 { font-size: 1.3rem; color: #1a263a; margin-bottom: 8px; }
        .subtitle { font-size: 0.9rem; color: #6b7280; margin-bottom: 32px; line-height: 1.6; }
        
        .form-group { text-align: left; margin-bottom: 20px; }
        .form-label { display: block; font-size: 0.9rem; color: #374151; font-weight: 600; margin-bottom: 8px; }
        .form-control { width: 100%; padding: 12px 16px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; color: #1f2937; transition: border-color 0.2s; font-family: inherit; }
        .form-control:focus { outline: none; border-color: #1a6b9a; box-shadow: 0 0 0 3px rgba(26, 107, 154, 0.1); }
        .form-control.otp { font-size: 1.5rem; text-align: center; letter-spacing: 5px; font-family: monospace; }
        
        .btn-primary { width: 100%; padding: 12px; background: #1a6b9a; color: white; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.2s; margin-top: 10px; }
        .btn-primary:hover { background: #15557a; }
        
        .error-message { background: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 8px; font-size: 0.9rem; margin-bottom: 20px; border: 1px solid #fca5a5; }

        .register-text { margin-top: 24px; font-size: 0.9rem; color: #6b7280; }
        .register-text a { color: #1a6b9a; text-decoration: none; font-weight: 600; }
        .register-text a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo">
            <i class="fas fa-lock-open"></i>
            <span>BiliTool.Vn</span>
        </div>

        @if (lang == "en")
        {
            <h1>Set New Password</h1>
            <p class="subtitle">Enter the OTP code received via email and your new password.</p>
        }
        else if (lang == "fr")
        {
            <h1>Définir un nouveau mot de passe</h1>
            <p class="subtitle">Saisissez le code OTP reçu par e-mail et votre nouveau mot de passe.</p>
        }
        else
        {
            <h1>Đặt lại mật khẩu mới</h1>
            <p class="subtitle">Nhập mã OTP đã nhận qua email và mật khẩu mới.</p>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-message">
                <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <input type="hidden" name="Email" value="@Model.Email" />
            
            <div class="form-group">
                @if (lang == "en")
                {
                    <label class="form-label" for="OtpCode">OTP Code</label>
                }
                else if (lang == "fr")
                {
                    <label class="form-label" for="OtpCode">Code OTP</label>
                }
                else
                {
                    <label class="form-label" for="OtpCode">Mã OTP</label>
                }
                <input type="text" id="OtpCode" name="OtpCode" class="form-control otp" maxlength="6" autocomplete="off" required placeholder="000000" />
            </div>

            <div class="form-group">
                @if (lang == "en")
                {
                    <label class="form-label" for="NewPassword">New Password</label>
                }
                else if (lang == "fr")
                {
                    <label class="form-label" for="NewPassword">Nouveau mot de passe</label>
                }
                else
                {
                    <label class="form-label" for="NewPassword">Mật khẩu mới</label>
                }
                <input type="password" id="NewPassword" name="NewPassword" class="form-control" required placeholder="••••••••" />
            </div>

            <div class="form-group">
                @if (lang == "en")
                {
                    <label class="form-label" for="ConfirmPassword">Confirm New Password</label>
                }
                else if (lang == "fr")
                {
                    <label class="form-label" for="ConfirmPassword">Confirmer le nouveau mot de passe</label>
                }
                else
                {
                    <label class="form-label" for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                }
                <input type="password" id="ConfirmPassword" name="ConfirmPassword" class="form-control" required placeholder="••••••••" />
            </div>

            @if (lang == "en")
            {
                <button type="submit" class="btn-primary">Complete Reset</button>
            }
            else if (lang == "fr")
            {
                <button type="submit" class="btn-primary">Réinitialisation terminée</button>
            }
            else
            {
                <button type="submit" class="btn-primary">Hoàn tất đặt lại</button>
            }
        </form>

        <p class="register-text">
            @if (lang == "en")
            {
                <a href="/dang-nhap"><i class="fas fa-arrow-left"></i> Cancel and go back</a>
            }
            else if (lang == "fr")
            {
                <a href="/dang-nhap"><i class="fas fa-arrow-left"></i> Annuler et retourner</a>
            }
            else
            {
                <a href="/dang-nhap"><i class="fas fa-arrow-left"></i> Hủy và quay lại</a>
            }
        </p>
    </div>
</body>
</html>
