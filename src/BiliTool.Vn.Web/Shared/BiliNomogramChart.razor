@using BiliTool.Vn.Application.DTOs
@using System.Globalization
<div class="bili-nomogram-container" role="img" aria-label="Biểu đồ ngưỡng bilirubin theo tuổi giờ">
    <div class="bili-nomogram-header">
        <div class="nomogram-eyebrow">Clinical nomogram</div>
        <div class="nomogram-title">
            BiliGraph Thresholds
        </div>
        <div class="nomogram-subtitle">
            @if (DonVi == "UmolL")
            {
                @KetQua.BilirubinUmolL.ToString("F0")<span> μmol/L @@ @KetQua.TuoiGio giờ | Tuổi thai: @KetQua.TuoiThaiTuan tuần | Nguy cơ TK: @(KetQua.CoNguyCoThanKinh ? "Có" : "Không")</span>
            }
            else
            {
                @KetQua.BilirubinMgDl.ToString("F1")<span> mg/dL @@ @KetQua.TuoiGio giờ | Tuổi thai: @KetQua.TuoiThaiTuan tuần | Nguy cơ TK: @(KetQua.CoNguyCoThanKinh ? "Có" : "Không")</span>
            }
        </div>
        <div class="nomogram-legend">
            <span class="legend-item"><span class="legend-color pt-color"></span> Chiếu đèn</span>
            <span class="legend-item"><span class="legend-color esc-color"></span> Chiếu tích cực</span>
            <span class="legend-item"><span class="legend-color et-color"></span> Thay máu</span>
            <span class="legend-item legend-patient"><span class="legend-diamond">◆</span> Bệnh nhi</span>
        </div>
    </div>

    <div class="bili-nomogram-svg-wrapper">
        <svg viewBox="0 0 @width @height" preserveAspectRatio="xMidYMid meet" class="bili-nomogram-svg">
            <defs>
                <linearGradient id="bili-chart-surface" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#f8fbff" />
                    <stop offset="100%" stop-color="#eef7fb" />
                </linearGradient>
                <filter id="patient-glow" x="-80%" y="-80%" width="260%" height="260%">
                    <feGaussianBlur stdDeviation="4" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>
            <rect x="0" y="0" width="@width" height="@height" rx="22" class="chart-surface" />
            <!-- Grid lines -->
            @if (DonVi == "UmolL")
            {
                @for (int i = 0; i <= 500; i += 100)
                {
                    <line x1="@PaddingLeft" y1="@(GetY(i).ToString(CultureInfo.InvariantCulture))" x2="@(width - PaddingRight)" y2="@(GetY(i).ToString(CultureInfo.InvariantCulture))" class="grid-line" />
                    @((MarkupString)FormattableString.Invariant($"<text x='{PaddingLeft - 10}' y='{GetY(i) + 4}' class='axis-label y-axis'>{i}</text>"))
                }
            }
            else
            {
                @for (int i = 0; i <= 30; i += 6)
                {
                    <line x1="@PaddingLeft" y1="@(GetY(i).ToString(CultureInfo.InvariantCulture))" x2="@(width - PaddingRight)" y2="@(GetY(i).ToString(CultureInfo.InvariantCulture))" class="grid-line" />
                    @((MarkupString)FormattableString.Invariant($"<text x='{PaddingLeft - 10}' y='{GetY(i) + 4}' class='axis-label y-axis'>{i}</text>"))
                }
            }
            
            @{ int xStep = MaxX > 168 ? 48 : 24; }
            @for (int i = 0; i <= MaxX; i += xStep)
            {
                <line x1="@(GetX(i).ToString(CultureInfo.InvariantCulture))" y1="@PaddingTop" x2="@(GetX(i).ToString(CultureInfo.InvariantCulture))" y2="@(height - PaddingBottom)" class="grid-line" />
                @((MarkupString)FormattableString.Invariant($"<text x='{GetX(i)}' y='{height - PaddingBottom + 15}' class='axis-label x-axis'>{i}</text>"))
            }

            <!-- Axis labels -->
            @((MarkupString)FormattableString.Invariant($"<text x='15' y='{height / 2}' transform='rotate(-90 15 {height / 2})' class='axis-title'>Bilirubin ({(DonVi == "UmolL" ? "μmol/L" : "mg/dL")})</text>"))
            @((MarkupString)FormattableString.Invariant($"<text x='{width / 2}' y='{height - 5}' class='axis-title'>Tuổi (giờ)</text>"))

            @if (KetQua.ChartData != null && KetQua.ChartData.Any())
            {
                <!-- Lines -->
                <polyline points="@GetPoints(d => d.Phototherapy)" class="line-pt" />
                <polyline points="@GetPoints(d => d.Escalation)" class="line-esc" />
                <polyline points="@GetPoints(d => d.Exchange)" class="line-et" />
            }

            <!-- Current Patient Point -->
            <polygon points="@GetDiamondPoints(KetQua.TuoiGio, DonVi == "UmolL" ? (double)KetQua.BilirubinUmolL : (double)KetQua.BilirubinMgDl)" class="patient-point" />
        </svg>
    </div>
</div>

<style>
    .bili-nomogram-container {
        background:
            linear-gradient(145deg, rgba(255,255,255,.98), rgba(237,248,252,.92)),
            radial-gradient(circle at 12% 8%, rgba(15,95,143,.12), transparent 34%);
        border: 1px solid rgba(15, 95, 143, .12);
        border-radius: 24px;
        padding: 18px;
        color: #0f172a;
        margin-top: 18px;
        box-shadow: 0 18px 44px rgba(8, 45, 77, .12), inset 0 1px 0 rgba(255,255,255,.9);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        overflow: hidden;
    }
    .bili-nomogram-header {
        text-align: left;
        margin-bottom: 14px;
    }
    .nomogram-eyebrow {
        color: #0f766e;
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .12em;
        text-transform: uppercase;
        margin-bottom: 4px;
    }
    .nomogram-title {
        color: #07111f;
        font-weight: 900;
        font-size: clamp(1rem, 1.6vw, 1.22rem);
        letter-spacing: -.035em;
    }
    .nomogram-subtitle {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 6px;
        font-size: 0.82rem;
        color: #475569;
        margin-top: 6px;
        margin-bottom: 14px;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(15, 95, 143, .07);
        border: 1px solid rgba(15, 95, 143, .10);
    }
    .nomogram-legend {
        display: flex;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 0.78rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 7px;
        color: #334155;
        font-weight: 800;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.74);
        border: 1px solid rgba(15,23,42,.08);
        box-shadow: 0 8px 18px rgba(15,23,42,.04);
    }
    .legend-color {
        width: 24px;
        height: 3px;
        border-radius: 999px;
        display: inline-block;
    }
    .pt-color { background: linear-gradient(90deg, #0f5f8f, #38bdf8); }
    .esc-color { background: linear-gradient(90deg, #b7791f, #fbbf24); }
    .et-color { background: linear-gradient(90deg, #b42318, #fb7185); }
    .legend-patient { border-color: rgba(15,118,110,.18); color: #0f766e; }
    .legend-diamond {
        color: #0f766e;
        font-size: 1.2rem;
        line-height: 1;
    }

    .bili-nomogram-svg-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        border-radius: 22px;
        background: rgba(255,255,255,.68);
        border: 1px solid rgba(15,23,42,.06);
        padding: 8px;
    }
    .bili-nomogram-svg {
        width: 100%;
        max-width: 800px;
        height: auto;
    }
    .grid-line {
        stroke: rgba(15, 95, 143, .10);
        stroke-width: 1;
    }
    .axis-label {
        fill: #64748b;
        font-size: 11px;
        font-weight: 700;
    }
    .y-axis { text-anchor: end; }
    .x-axis { text-anchor: middle; }
    .axis-title {
        fill: #475569 !important;
        color: #475569 !important;
        font-size: 12px;
        font-weight: 800;
        text-anchor: middle;
    }
    .chart-surface {
        fill: url(#bili-chart-surface);
        stroke: rgba(15, 95, 143, .08);
        stroke-width: 1;
    }
    .line-pt {
        fill: none;
        stroke: #0f5f8f;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .line-esc {
        fill: none;
        stroke: #b7791f;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .line-et {
        fill: none;
        stroke: #b42318;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .patient-point {
        fill: #ffffff;
        stroke: #0f766e;
        stroke-width: 4;
        filter: url(#patient-glow);
    }

    @@media (max-width: 640px) {
        .bili-nomogram-container { padding: 14px; border-radius: 20px; }
        .nomogram-legend { gap: 6px; }
        .legend-item { width: calc(50% - 3px); justify-content: center; padding: 7px 8px; }
        .bili-nomogram-svg-wrapper { padding: 4px; overflow-x: auto; }
        .bili-nomogram-svg { min-width: 520px; }
    }
</style>

@code {
    [Parameter] public KetQuaTinhToanDto KetQua { get; set; } = default!;
    [Parameter] public string DonVi { get; set; } = "UmolL";

    private int width = 800;
    private int height = 400;
    private int PaddingLeft = 50;
    private int PaddingRight = 20;
    private int PaddingTop = 20;
    private int PaddingBottom = 40;

    private int MaxX => KetQua.ChartData?.Any() == true ? (int)KetQua.ChartData.Max(d => d.Hour) : 336;
    private int MaxY => DonVi == "UmolL" ? 513 : 30;

    private double GetX(double hour)
    {
        if (MaxX == 0) return PaddingLeft;
        return PaddingLeft + (hour / MaxX) * (width - PaddingLeft - PaddingRight);
    }

    private double GetY(double bili)
    {
        return height - PaddingBottom - (bili / MaxY) * (height - PaddingTop - PaddingBottom);
    }

    private string GetPoints(Func<ChartDataPoint, decimal> selector)
    {
        if (KetQua.ChartData == null) return "";
        var pts = KetQua.ChartData.Select(d => {
            double val = (double)selector(d);
            if (DonVi == "UmolL")
            {
                val = val * 17.104;
            }
            return FormattableString.Invariant($"{GetX(d.Hour)},{GetY(val)}");
        }).ToList();
        return string.Join(" ", pts);
    }

    private string GetDiamondPoints(double x, double y)
    {
        double cx = GetX(x);
        double cy = GetY(y);
        double size = 6;
        return FormattableString.Invariant($"{cx},{cy - size} {cx + size},{cy} {cx},{cy + size} {cx - size},{cy}");
    }
}
