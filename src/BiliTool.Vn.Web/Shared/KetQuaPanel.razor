@using BiliTool.Vn.Application.DTOs

<div class="ket-qua-card" style="border-left: 6px solid @KetQua.MauNguyHiem;">
    <div class="ket-qua-header" style="background: @LayMauNen(); justify-content: right;">
        <span class="ket-qua-title">@T["ClinicalResult"]</span>
        <span class="thoi-gian-tinh">@((KetQua.ThoiGianLayMau ?? KetQua.ThoiGianTinhToan).ToString("HH:mm dd/MM/yyyy"))</span>
    </div>

    <div class="ket-qua-body" id="ket-qua-pdf">
        <!-- Badge To Rõ Ràng -->
        <div class="muc-do-badge-huge" style="background: @KetQua.MauNguyHiem; color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; line-height: 1.2;">
            <div>
                <i class="fas @LayIconMucDo()"></i>
                @T[$"MucDo_{KetQua.MucDoNguyHiemEnum}"].ToString().ToUpper()
            </div>
            <div style="font-size: 0.85rem; margin-top: 6px; font-weight: 600; text-transform: none; background: rgba(0,0,0,0.45); color: #fff; padding: 4px 10px; border-radius: 999px;">
                (@T["ProtocolInterpretation"]: @(KetQua.PhacDoQuyetDinh == BiliTool.Vn.Domain.Enums.PhacDo.AAP2022 ? "AAP 2022" : "NICE CG98"))
            </div>
        </div>

        <!-- Thông số tóm tắt -->
        <div class="thong-so-row mt-3">
            <div class="thong-so-item">
                <span class="ts-label">@T["Age"]</span>
                <span class="ts-value">@string.Format(T["Age_Hours"], KetQua.TuoiGio)</span>
            </div>
            <div class="thong-so-item">
                <span class="ts-label">@T["GestationalAge"]</span>
                <span class="ts-value">@KetQua.TuoiThaiTuan @T["Weeks_Short"]</span>
            </div>
            <div class="thong-so-item">
                <span class="ts-label">Bilirubin</span>
                <span class="ts-value">
                    @if (DonVi == "UmolL")
                    {
                        @KetQua.BilirubinUmolL.ToString("F0")<span> μmol/L</span>
                        <small>(@KetQua.BilirubinMgDl.ToString("F1") mg/dL)</small>
                    }
                    else
                    {
                        @KetQua.BilirubinMgDl.ToString("F1")<span> mg/dL</span>
                        <small>(@KetQua.BilirubinUmolL.ToString("F0") μmol/L)</small>
                    }
                </span>
            </div>
            <div class="thong-so-item">
                <span class="ts-label">@T["CalcBili_Risk"]</span>
                <span class="ts-value @(KetQua.CoNguyCoThanKinh ? "text-danger" : "text-success")">
                    @(KetQua.CoNguyCoThanKinh ? T["Yes"] : T["No"])
                </span>
            </div>
        </div>

        <!-- Thanh ngưỡng (được thay thế bằng Biểu đồ Nomogram) -->
        <BiliNomogramChart KetQua="@KetQua" DonVi="@DonVi" />

        <!-- Khoảng cách -->
        <div class="khoang-cach-grid">
            <div class="khoang-cach-item @(KetQua.CanChieuDenNgay ? "alert-style" : "")">
                <span>@T["ToPhototherapyThreshold"]</span>
                <strong class="@LayClassKhoangCach(KetQua.KhoangCachDenNguongChieuDen)">
                    @FormatKhoangCach(KetQua.KhoangCachDenNguongChieuDen)
                </strong>
            </div>
            <div class="khoang-cach-item @(KetQua.CanXemXetThayCuuMau ? "alert-style" : "")">
                <span>@T["ToExchangeThreshold"]</span>
                <strong class="@LayClassKhoangCach(KetQua.KhoangCachDenNguongThayCuuMau)">
                    @FormatKhoangCach(KetQua.KhoangCachDenNguongThayCuuMau)
                </strong>
            </div>
        </div>

        <!-- Khuyến nghị -->
        <div class="khuyen-nghi-box" style="border-color: @KetQua.MauNguyHiem;">
            <div class="khuyen-nghi-title">
                <i class="fas fa-stethoscope"></i>
                @T["CalcBili_Recommendation"]
            </div>
            
            <p class="khuyen-nghi-chinh">
                @if (KetQua.TuoiGio < 12)
                {
                    <strong class="text-danger">@T["Warning_Under12h"]</strong><br/>
                }
                @GetKhuyenNghiChinh()
            </p>
            
            <div class="theo-doi-tiep">
                <i class="fas fa-calendar-check"></i>
                <strong>@T["CalcBili_FollowUp"]:</strong> @GetTheoDoiTiepTheo()
            </div>
            
            <div class="tai-kham-badge">
                <i class="fas fa-clock"></i>
                @T["FW_" + KetQua.ThoiGianTaiKhamEnum.ToString()]
            </div>
        </div>

        <!-- ══════ NICE CG98: Cảnh báo Kernicterus ══════ -->
        @if (KetQua.NguyCoKernicterus)
        {
            <div class="nice-alert nice-alert-danger">
                <div class="nice-alert-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div>
                    <strong>@T["KernicterusRiskTitle"]</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var lyDo in KetQua.LyDoNguyCoKernicterus)
                        {
                            <li>@lyDo</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- ══════ NICE CG98: IVIG ══════ -->
        @if (KetQua.CanIVIG)
        {
            <div class="nice-alert nice-alert-warning">
                <div class="nice-alert-icon"><i class="fas fa-syringe"></i></div>
                <div>
                    <strong>@T["IVIGIndicationTitle"]</strong>
                    <p class="mb-0 mt-1">@KetQua.MoTaIVIG</p>
                </div>
            </div>
        }

        <!-- ══════ NICE CG98: Vàng da kéo dài ══════ -->
        @if (KetQua.LaVangDaKeoDai)
        {
            <div class="nice-alert nice-alert-info">
                <div class="nice-alert-icon"><i class="fas fa-hourglass-half"></i></div>
                <div>
                    <strong>@T["ProlongedJaundiceTitle"]</strong>
                    <p class="mb-0 mt-1">@KetQua.CanhBaoVangDaKeoDai</p>
                </div>
            </div>
        }

        <!-- ══════ NICE CG98: Dừng chiếu đèn / Rebound ══════ -->
        @if (KetQua.CoTheDungChieuDen)
        {
            <div class="nice-alert nice-alert-success">
                <div class="nice-alert-icon"><i class="fas fa-stop-circle"></i></div>
                <div>
                    <strong>@T["CanStopPhotoTitle"]</strong>
                    <p class="mb-0 mt-1">@T["CanStopPhotoDesc"]</p>
                </div>
            </div>
        }
        @if (KetQua.CanKiemTraRebound)
        {
            <div class="nice-alert nice-alert-warning">
                <div class="nice-alert-icon"><i class="fas fa-redo"></i></div>
                <div>
                    <strong>@T["ReboundCheckTitle"]</strong>
                    <p class="mb-0 mt-1">@T["ReboundCheckDesc"]</p>
                </div>
            </div>
        }

        <!-- ══════ Ngưỡng tham chiếu NICE CG98 ══════ -->
        <div class="nice-thresholds-box">
            <div class="nice-thresholds-title">
                <i class="fas fa-book-medical"></i> @T["NiceRefThresholdTitle"]
            </div>
            <div class="nice-thresholds-grid">
                <div class="nice-th-item">
                    <span class="nice-th-label">@T["Phototherapy"]</span>
                    <span class="nice-th-value">@KetQua.NguongChieuDen_NICE_UmolL µmol/L</span>
                    <span class="nice-th-sub">≈ @KetQua.NguongChieuDen_NICE_MgDl mg/dL</span>
                </div>
                <div class="nice-th-item">
                    <span class="nice-th-label">@T["ExchangeTransfusion"]</span>
                    <span class="nice-th-value">@KetQua.NguongThayCuuMau_NICE_UmolL µmol/L</span>
                    <span class="nice-th-sub">≈ @KetQua.NguongThayCuuMau_NICE_MgDl mg/dL</span>
                </div>
            </div>
        </div>

        <!-- ══════ Lịch đo lặp NICE ══════ -->
        @if (!string.IsNullOrEmpty(KetQua.LichDoLapNICE))
        {
            <div class="nice-repeat-box">
                <i class="fas fa-vial"></i>
                <span>@KetQua.LichDoLapNICE</span>
                @if (KetQua.GioDoLapTiepTheo.HasValue)
                {
                    <span class="nice-repeat-badge">@KetQua.GioDoLapTiepTheo h</span>
                }
            </div>
        }

        <!-- ══════ Chú thích nguồn tham chiếu ══════ -->
        <div class="nice-references">
            <div class="nice-ref-title"><i class="fas fa-info-circle"></i> @T["ReferenceSource"]</div>
            <div class="nice-ref-badge">
                @T["DecisiveProtocol"]: <strong>@(KetQua.PhacDoQuyetDinh == BiliTool.Vn.Domain.Enums.PhacDo.AAP2022 ? "AAP 2022" : "NICE CG98")</strong>
            </div>
            <ul class="nice-ref-list">
                @foreach (var ct in KetQua.ChuThichThamChieu)
                {
                    <li>@ct</li>
                }
            </ul>
        </div>

        <!-- Actions -->
        <div class="action-buttons">
            <button class="btn-primary-vn" @onclick="OnTaoHoSoClicked" style="grid-column: 1 / -1; margin-bottom: 8px;">
                <i class="fas fa-user-plus"></i> @T["Trend_Create"]
            </button>
            <button class="btn-copy" @onclick="HandleSaoChep">
                <i class="fas fa-copy"></i> @T["CopyReport"]
            </button>
            <button class="btn-print text-white bg-primary bg-gradient" style="border: none;" @onclick="OnIn">
                <i class="fas fa-file-pdf"></i> @T["ExportPdf"]
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public KetQuaTinhToanDto KetQua { get; set; } = default!;
    [Parameter] public string DonVi { get; set; } = "UmolL";
    [Parameter] public EventCallback<string> OnSaoChep { get; set; }
    [Parameter] public EventCallback OnIn { get; set; }
    [Parameter] public EventCallback OnTaoHoSo { get; set; }
    @inject BiliTool.Vn.Web.Services.TranslationService T
    @inject IJSRuntime JS

    private async Task HandleSaoChep()
    {
        var text = XuatVanBanBaoCao();
        if (OnSaoChep.HasDelegate)
        {
            await OnSaoChep.InvokeAsync(text);
        }
    }

    private async Task OnTaoHoSoClicked()
    {
        if (OnTaoHoSo.HasDelegate)
        {
            await OnTaoHoSo.InvokeAsync();
        }
    }

    private string LayMauNen() => KetQua.MauNguyHiem switch
    {
        "#27ae60" => "#eafaf1",
        "#f39c12" => "#fef9e7",
        "#e67e22" => "#fef5e7",
        _ => "#fdecea"
    };

    private string LayIconMucDo() => KetQua.MucDoNguyHiemEnum.ToString() switch
    {
        "BinhThuong" => "fa-check-circle",
        "CanTheoDoiSat" => "fa-eye",
        "CanChieuDen" => "fa-sun",
        "CanChieuDenTichCuc" => "fa-bolt",
        "CanXemXetThayMau" => "fa-tint",
        "KhanCapThayCuuMau" => "fa-exclamation-triangle",
        _ => "fa-question-circle"
    };

    private string LayClassKhoangCach(decimal d) =>
        d < 0 ? "text-danger fw-bold" :
        d < 2 ? "text-warning fw-bold" :
        "text-success";

    private string FormatKhoangCach(decimal d)
    {
        if (DonVi == "UmolL")
        {
            decimal u = d * 17.104m;
            return u < 0
                ? $"{T["Exceeded"]} {Math.Abs(Math.Round(u, 0)):F0} μmol/L"
                : $"{T["Remaining"]} {Math.Round(u, 0):F0} μmol/L";
        }
        else
        {
            return d < 0
                ? $"{T["Exceeded"]} {Math.Abs(d):F1} mg/dL"
                : $"{T["Remaining"]} {d:F1} mg/dL";
        }
    }

    private string GetKhuyenNghiChinh()
    {
        var e = KetQua.MucDoNguyHiemEnum.ToString();
        var template = T[$"Rec_{e}"].ToString();
        
        if (DonVi == "UmolL")
        {
            template = template.Replace("mg/dL", "μmol/L").Replace("mg/dl", "μmol/l");
            decimal val0 = Math.Round(KetQua.BilirubinUmolL, 0);
            decimal val1 = Math.Round(KetQua.NguongChieuDen * 17.104m, 0);
            var baseStr = string.Format(template, val0, val1);
            if (e == "CanTheoDoiSat")
            {
                baseStr += " " + (KetQua.CoNguyCoThanKinh ? T["Rec_CanTheoDoiSat_Risk"] : T["Rec_CanTheoDoiSat_NoRisk"]);
            }
            return baseStr;
        }
        else
        {
            var baseStr = string.Format(template, KetQua.BilirubinMgDl, KetQua.NguongChieuDen);
            if (e == "CanTheoDoiSat")
            {
                baseStr += " " + (KetQua.CoNguyCoThanKinh ? T["Rec_CanTheoDoiSat_Risk"] : T["Rec_CanTheoDoiSat_NoRisk"]);
            }
            return baseStr;
        }
    }

    private string GetTheoDoiTiepTheo()
    {
        return T["FW_" + KetQua.ThoiGianTaiKhamEnum.ToString()];
    }

    public string XuatVanBanBaoCao()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"=== {T["CalcBili_ReportHeader"]} ===");
        if (KetQua.ThoiGianLayMau.HasValue)
            sb.AppendLine($"{T["SampleTime"]}: {KetQua.ThoiGianLayMau.Value:dd/MM/yyyy HH:mm}");
        sb.AppendLine($"{T["GestationalAge"]}: {KetQua.TuoiThaiTuan} {T["WeeksTerm"].Split(' ')[0]}");
        sb.AppendLine($"{T["AgeSampleHours"]}: {KetQua.TuoiGio:F1} {T["Hours"]}");
        if (DonVi == "UmolL")
        {
            sb.AppendLine($"{T["TotalBilirubin"]}: {KetQua.BilirubinUmolL:F0} μmol/L ({KetQua.BilirubinMgDl:F1} mg/dL)");
        }
        else
        {
            sb.AppendLine($"{T["TotalBilirubin"]}: {KetQua.BilirubinMgDl:F1} mg/dL ({KetQua.BilirubinUmolL:F0} μmol/L)");
        }
        sb.AppendLine($"{T["CalcBili_Risk"]}: {(KetQua.CoNguyCoThanKinh ? T["Yes"] : T["No"])}");
        
        sb.AppendLine("--- AAP 2022 ---");
        if (DonVi == "UmolL")
        {
            sb.AppendLine($"{T["CalcBili_ThresholdChieuDen"]}: {Math.Round(KetQua.NguongChieuDen * 17.104m, 0):F0} μmol/L");
            sb.AppendLine($"{T["CalcBili_ThresholdChieuDenTichCuc"]}: {Math.Round(KetQua.NguongChieuDenTichCuc * 17.104m, 0):F0} μmol/L");
            sb.AppendLine($"{T["CalcBili_ThresholdThayMau"]}: {Math.Round(KetQua.NguongThayCuuMau * 17.104m, 0):F0} μmol/L");
        }
        else
        {
            sb.AppendLine($"{T["CalcBili_ThresholdChieuDen"]}: {KetQua.NguongChieuDen:F1} mg/dL");
            sb.AppendLine($"{T["CalcBili_ThresholdChieuDenTichCuc"]}: {KetQua.NguongChieuDenTichCuc:F1} mg/dL");
            sb.AppendLine($"{T["CalcBili_ThresholdThayMau"]}: {KetQua.NguongThayCuuMau:F1} mg/dL");
        }
        
        sb.AppendLine("--- NICE CG98 ---");
        sb.AppendLine($"{T["Phototherapy"]} NICE: {KetQua.NguongChieuDen_NICE_UmolL} µmol/L (≈{KetQua.NguongChieuDen_NICE_MgDl} mg/dL)");
        sb.AppendLine($"{T["ExchangeTransfusion"]} NICE: {KetQua.NguongThayCuuMau_NICE_UmolL} µmol/L (≈{KetQua.NguongThayCuuMau_NICE_MgDl} mg/dL)");
        sb.AppendLine("---");
        sb.AppendLine($"{T["DecisiveProtocol"]}: {(KetQua.PhacDoQuyetDinh == BiliTool.Vn.Domain.Enums.PhacDo.AAP2022 ? "AAP 2022" : "NICE CG98")}");
        sb.AppendLine($"{T["CalcBili_Evaluation"]}: {T[$"MucDo_{KetQua.MucDoNguyHiemEnum}"]} ({T["ReferenceSource"]}: {(KetQua.PhacDoQuyetDinh == BiliTool.Vn.Domain.Enums.PhacDo.AAP2022 ? "AAP 2022" : "NICE CG98")})");
        sb.AppendLine($"{T["CalcBili_Recommendation"]}: {GetKhuyenNghiChinh()}");
        sb.AppendLine($"{T["CalcBili_FollowUp"]}: {GetTheoDoiTiepTheo()}");
        if (KetQua.NguyCoKernicterus)
            sb.AppendLine($"⚠️ NGUY CƠ KERNICTERUS: {string.Join("; ", KetQua.LyDoNguyCoKernicterus)}");
        if (KetQua.CanIVIG)
            sb.AppendLine($"💉 IVIG: {KetQua.MoTaIVIG}");
        if (KetQua.LaVangDaKeoDai)
            sb.AppendLine($"⏰ {KetQua.CanhBaoVangDaKeoDai}");
        if (!string.IsNullOrEmpty(KetQua.LichDoLapNICE))
            sb.AppendLine($"🔬 {KetQua.LichDoLapNICE}");
        sb.AppendLine("=== BiliTool.Vn | AAP 2022 + NICE CG98 | bilitool.vn ===");
        return sb.ToString();
    }
}
