@using System.Text.Json

<script type="application/ld+json">@((MarkupString)SchemaJson)</script>

@code {
    [Parameter, EditorRequired]
    public string PageType { get; set; } = "MedicalWebPage";

    [Parameter, EditorRequired]
    public string Path { get; set; } = "/";

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public string Language { get; set; } = "vi";

    private string SchemaJson => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@graph"] = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@type"] = PageType,
                ["@id"] = $"https://bilitool.vn{Path}#content",
                ["url"] = $"https://bilitool.vn{Path}?culture={Language}&ui-culture={Language}",
                ["name"] = Title,
                ["description"] = Description,
                ["inLanguage"] = Language,
                ["datePublished"] = "2026-07-10",
                ["dateModified"] = "2026-07-12",
                ["author"] = new Dictionary<string, object?> { ["@id"] = "https://bilitool.vn/gioi-thieu#physician" },
                ["reviewedBy"] = new Dictionary<string, object?> { ["@id"] = "https://bilitool.vn/gioi-thieu#physician" },
                ["publisher"] = new Dictionary<string, object?> { ["@id"] = "https://bilitool.vn/#organization" },
                ["isPartOf"] = new Dictionary<string, object?> { ["@id"] = "https://bilitool.vn/#website" },
                ["citation"] = new[]
                {
                    "Kemper AR, et al. Pediatrics. 2022;150(3):e2022058859.",
                    "NICE Clinical Guideline CG98. Updated 31 October 2023."
                }
            },
            new Dictionary<string, object?>
            {
                ["@type"] = new[] { "Person", "Physician" },
                ["@id"] = "https://bilitool.vn/gioi-thieu#physician",
                ["name"] = "Ninh Thị Phương Mai",
                ["honorificPrefix"] = "ThS. BS.",
                ["jobTitle"] = "Bác sĩ Nhi khoa",
                ["worksFor"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Hospital",
                    ["name"] = "Bệnh viện E"
                },
                ["url"] = "https://bilitool.vn/gioi-thieu",
                ["sameAs"] = new[] { "https://drninhmai.com/" }
            },
            new Dictionary<string, object?>
            {
                ["@type"] = "BreadcrumbList",
                ["itemListElement"] = new object[]
                {
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 1,
                        ["name"] = "BiliTool.Vn",
                        ["item"] = "https://bilitool.vn/"
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 2,
                        ["name"] = Title,
                        ["item"] = $"https://bilitool.vn{Path}"
                    }
                }
            }
        }
    });
}
